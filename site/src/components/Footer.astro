        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    background: var(--bg-soft);
    margin-top: 4rem;
  }

  .inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 2.5rem var(--space);
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem 4rem;
  }

  .brand {
    max-width: 20rem;
  }

  .brand p {
    margin: 0.75rem 0 0;
    font-size: 0.88rem;
    color: var(--muted);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem 4rem;
  }

  .col {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-width: 9rem;
  }

  .col-title {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg);
    margin: 0 0 0.25rem;
  }

  .col a {
    font-size: 0.88rem;
    color: var(--muted);
  }

  .col a:hover {
    color: var(--accent);
  }

  .bottom {
    border-top: 1px solid var(--border);
  }

  .bottom-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 1rem var(--space);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .bottom p {
    margin: 0;
    font-size: 0.82rem;
    color: var(--muted);
  }

  .social {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .social a {
    display: flex;
    color: var(--muted);
  }

  .social a:hover {
    color: var(--accent);
  }
</style>
