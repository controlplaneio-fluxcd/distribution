<button id="theme-toggle" type="button" aria-label="Switch color theme" title="Switch color theme">
  <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
  </svg>
  <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
  </svg>
</button>

<style>
  button {
    display: inline-flex;
    align-items: center;
    background: none;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    color: var(--muted);
    padding: 0.4rem 0.5rem;
    cursor: pointer;
  }

  button:hover {
    color: var(--fg);
    border-color: var(--muted);
  }

  :global([data-theme='light']) .icon-sun {
    display: none;
  }

  :global([data-theme='dark']) .icon-moon {
    display: none;
  }

  /* Marketing pages are light-only — no toggle there */
  :global([data-forced-theme]) button {
    display: none;
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle')!;
  toggle.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    const system = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    if (next === system) {
      localStorage.removeItem('theme');
    } else {
      localStorage.setItem('theme', next);
    }
  });
</script>
