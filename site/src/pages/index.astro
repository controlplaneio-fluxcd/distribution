---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactUrl } from '../lib/nav';

const trust = [
  { value: 'SLSA Level 3', label: 'Supply chain security' },
  { value: 'FIPS 140-3', label: 'Compliant crypto builds' },
  { value: 'Zero CVEs', label: 'Continuous patching with SLAs' },
  { value: 'CNCF maintainers', label: 'Built by Flux core maintainers' },
];

const features = [
  {
    title: 'Hardened images',
    body: 'Distroless container images for the Flux controllers with no shell or package manager, in-sync with upstream CNCF Flux releases.',
    icon: 'M4 7l8-4 8 4-8 4-8-4zm0 5l8 4 8-4M4 17l8 4 8-4',
  },
  {
    title: 'Zero CVEs',
    body: 'Continuous vulnerability scanning and CVE patching for the Flux controllers, with SLAs for critical remediation.',
    icon: 'M12 3l7 3v5c0 4.5-3 8.5-7 10-4-1.5-7-5.5-7-10V6l7-3zm-3 9l2.2 2.2L15.5 9.9',
  },
  {
    title: 'FIPS compliance',
    body: 'FIPS-compliant Flux builds based on Go crypto FIPS 140-3 mode, with TLS and SSH restricted to approved settings.',
    icon: 'M7 11V7a5 5 0 0110 0v4m-12 0h14v10H5V11zm7 4v3',
  },
  {
    title: '24/7 support',
    body: 'Best-in-class expertise to securely design, deploy, and operate your Flux CD instances at scale, around the clock.',
    icon: 'M12 3a8 8 0 018 8v5a3 3 0 01-3 3h-1v-7h4M4 19v-8a8 8 0 018-8m-8 9H3m1 0h3v7H6a3 3 0 01-2-1',
  },
  {
    title: 'Kubernetes compatibility',
    body: 'Assured compatibility for OpenShift and Kubernetes LTS versions provided by AWS EKS, Azure AKS, and Google GKE.',
    icon: 'M12 8a4 4 0 100 8 4 4 0 000-8zm0-6v4m0 12v4M2 12h4m12 0h4M5 5l2.8 2.8m8.4 8.4L19 19M19 5l-2.8 2.8M7.8 16.2L5 19',
  },
  {
    title: 'Supply chain security',
    body: 'SLSA Build Level 3 pipeline shipping cryptographically signed images, SBOMs, and VEX documents.',
    icon: 'M12 3l2 2h5v5l2 2-2 2v5h-5l-2 2-2-2H5v-5l-2-2 2-2V5h5l2-2zm-3 9l2.2 2.2L15.5 9.9',
  },
  {
    title: 'Self-service capabilities',
    body: 'Preview environments and self-service workflows for GitHub, GitLab, and Azure DevOps pull request testing.',
    icon: 'M4 5h16v4H4V5zm0 10h16v4H4v-4zm3-8v0m0 10v0m5-10h5m-5 10h5',
  },
  {
    title: 'AI-assisted GitOps',
    body: 'The Flux MCP Server connects AI assistants to your clusters for natural-language troubleshooting and incident response.',
    icon: 'M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5L12 2zm7 11l.8 2.2L22 16l-2.2.8L19 19l-.8-2.2L16 16l2.2-.8L19 13zM6 15l1 2.5L9.5 18 7 19l-1 2.5L5 19l-2.5-1L5 17.5 6 15z',
  },
];

const addons = [
  {
    title: 'Flux Web UI',
    body: 'A dashboard for monitoring GitOps pipelines across clusters, with single sign-on and multi-tenancy built in.',
    href: '/addons/',
  },
  {
    title: 'Flux MCP Server',
    body: 'A read-only, hardened MCP server that lets AI assistants inspect Flux-managed clusters safely.',
    href: '/addons/',
  },
  {
    title: 'Dex IdP',
    body: 'A hardened Dex distribution providing OIDC-based single sign-on for the Flux Web UI and MCP Server.',
    href: '/addons/',
  },
];
---

<BaseLayout
  title="ControlPlane Enterprise for Flux CD"
  description="ControlPlane offers a hardened, enterprise-grade distribution and support services for the CNCF-graduated Flux project."
>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-copy">
        <p class="hero-eyebrow">Enterprise-grade GitOps</p>
        <h1>The hardened distribution of Flux&nbsp;CD</h1>
        <p class="hero-lead">
          Zero-CVE, FIPS-compliant Flux controllers with guaranteed remediation SLAs and 24/7
          support — built and maintained by the security experts and core maintainers behind
          the CNCF-graduated Flux project.
        </p>
        <div class="hero-actions">
          <a class="hero-button primary" href={contactUrl} target="_blank" rel="noopener">Request a demo</a>
          <a class="hero-button" href="/distribution/">Explore the distribution</a>
        </div>
      </div>
      <div class="hero-panel" aria-hidden="true">
        <div class="panel-bar">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="panel-file">flux-instance.yaml</span>
        </div>
        <pre class="panel-code"><code><span class="yk">apiVersion</span>: fluxcd.controlplane.io/v1
<span class="yk">kind</span>: FluxInstance
<span class="yk">metadata</span>:
  <span class="yk">name</span>: flux
  <span class="yk">namespace</span>: flux-system
<span class="yk">spec</span>:
  <span class="yk">distribution</span>:
    <span class="yk">version</span>: <span class="ys">"2.x"</span>
    <span class="yk">registry</span>: ghcr.io/controlplaneio-fluxcd
    <span class="yk">variant</span>: <span class="ys">distroless-fips</span>
  <span class="yk">cluster</span>:
    <span class="yk">multitenant</span>: <span class="yb">true</span></code></pre>
        <div class="panel-status">
          <span class="status-dot"></span>
          Reconciled — enterprise distribution up to date
        </div>
      </div>
    </div>
  </section>

  <section class="trust" aria-label="Compliance and assurance">
    <div class="trust-inner">
      {
        trust.map(({ value, label }) => (
          <div class="fact">
            <p class="fact-value">{value}</p>
            <p class="fact-label">{label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="features" aria-labelledby="features-title">
    <div class="section-head">
      <p class="eyebrow">product: distribution</p>
      <h2 id="features-title">Everything upstream Flux has, hardened for the enterprise</h2>
      <p class="section-lead">
        The ControlPlane distribution keeps full compatibility with CNCF Flux while adding the
        security assurance, compliance, and support that regulated environments require.
      </p>
    </div>
    <div class="grid">
      {
        features.map(({ title, body, icon }) => (
          <div class="card">
            <div class="icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={icon} />
              </svg>
            </div>
            <h3>{title}</h3>
            <p>{body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="addons" aria-labelledby="addons-title">
    <div class="section-head">
      <p class="eyebrow">product: addons</p>
      <h2 id="addons-title">Enterprise addons that extend Flux</h2>
      <p class="section-lead">
        Operate GitOps at scale with a web dashboard, AI-assisted troubleshooting, and single
        sign-on — all covered by the same CVE remediation SLAs as the distribution.
      </p>
    </div>
    <div class="addon-grid">
      {
        addons.map(({ title, body, href }) => (
          <a class="addon" href={href}>
            <h3>{title}</h3>
            <p>{body}</p>
            <span class="more">Learn more &rarr;</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <p class="cta-eyebrow">Get started</p>
      <h2>Run Flux in production with confidence</h2>
      <p>
        Get enterprise-hardened Flux controllers, guaranteed SLAs for CVE remediation, and direct
        access to Flux core maintainers.
      </p>
      <div class="cta-actions">
        <a class="cta-button primary" href={contactUrl} target="_blank" rel="noopener">Contact us</a>
        <a class="cta-button" href="/distribution/install/">Installation guide</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- Hero: navy in both themes ---------- */
  .hero {
    background:
      radial-gradient(56rem 30rem at 78% -10%, rgba(20, 114, 235, 0.28), transparent 60%),
      radial-gradient(40rem 24rem at 8% 110%, rgba(20, 114, 235, 0.14), transparent 60%),
      var(--navy-900);
    border-bottom: 1px solid var(--navy-line);
    color: #eef4fd;
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 5.5rem var(--space) 5rem;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 4rem;
    align-items: center;
    background-image:
      linear-gradient(rgba(114, 174, 250, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(114, 174, 250, 0.05) 1px, transparent 1px);
    background-size: 36px 36px;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--brand-light);
    margin: 0 0 1rem;
  }

  h1 {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin: 0 0 1.25rem;
    color: #ffffff;
  }

  .hero-lead {
    font-size: 1.08rem;
    line-height: 1.7;
    margin: 0 0 2rem;
    color: rgba(222, 233, 248, 0.85);
    max-width: 34rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-button {
    display: inline-block;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(190, 211, 252, 0.35);
    color: #ffffff;
    transition: background 0.15s, border-color 0.15s;
  }

  .hero-button:hover {
    background: rgba(114, 174, 250, 0.12);
    border-color: rgba(190, 211, 252, 0.6);
    text-decoration: none;
  }

  .hero-button.primary {
    background: var(--brand);
    border-color: var(--brand);
  }

  .hero-button.primary:hover {
    background: #2c82f2;
    border-color: #2c82f2;
  }

  /* The signature: a live FluxInstance resource, reconciled */
  .hero-panel {
    background: color-mix(in srgb, var(--navy-950) 82%, transparent);
    border: 1px solid var(--navy-line);
    border-radius: var(--radius-md);
    box-shadow: 0 24px 60px rgba(3, 8, 18, 0.5);
    overflow: hidden;
  }

  .panel-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--navy-line);
  }

  .dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: rgba(190, 211, 252, 0.18);
  }

  .panel-file {
    margin-left: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(190, 211, 252, 0.55);
  }

  .panel-code {
    margin: 0;
    padding: 1.1rem 1.25rem;
    border: 0;
    border-radius: 0;
    background: none;
    font-size: 0.78rem;
    line-height: 1.7;
    color: #d7e3f7;
  }

  .yk { color: var(--brand-light); }
  .ys { color: var(--brand-pale); }
  .yb { color: #34d399; }

  .panel-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-top: 1px solid var(--navy-line);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #34d399;
  }

  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #34d399;
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.7);
  }

  /* ---------- Trust strip ---------- */
  .trust {
    border-bottom: 1px solid var(--border);
    background: var(--bg-soft);
  }

  .trust-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 1.75rem var(--space);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .fact {
    padding-left: 1rem;
    border-left: 2px solid var(--accent);
  }

  .fact-value {
    font-weight: 700;
    font-size: 1.02rem;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .fact-label {
    font-size: 0.82rem;
    color: var(--muted);
    margin: 0.15rem 0 0;
  }

  /* ---------- Sections ---------- */
  .features,
  .addons {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 4.5rem var(--space) 0;
  }

  .section-head {
    max-width: 44rem;
    margin-bottom: 2.5rem;
  }

  .section-head h2 {
    font-size: clamp(1.6rem, 2.6vw, 2.1rem);
    margin: 0 0 0.75rem;
  }

  .section-lead {
    color: var(--muted);
    font-size: 1rem;
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem;
  }

  .card {
    padding: 1.4rem 1.3rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-soft);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    border-color: var(--brand-light);
    box-shadow: var(--shadow);
  }

  .icon {
    width: 2.4rem;
    height: 2.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--brand) 12%, transparent);
    color: var(--accent);
    margin-bottom: 0.9rem;
  }

  .card h3 {
    font-size: 1rem;
    margin: 0 0 0.4rem;
  }

  .card p {
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }

  .addon-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }

  .addon {
    display: block;
    padding: 1.5rem 1.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-soft);
    color: var(--fg);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .addon:hover {
    text-decoration: none;
    border-color: var(--brand-light);
    box-shadow: var(--shadow);
  }

  .addon h3 {
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
  }

  .addon p {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0 0 1rem;
    line-height: 1.6;
  }

  .more {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
  }

  /* ---------- CTA band: navy in both themes ---------- */
  .cta {
    max-width: var(--site-width);
    margin: 4.5rem auto 0;
    padding: 0 var(--space);
  }

  .cta-inner {
    border-radius: var(--radius-lg);
    background:
      radial-gradient(42rem 20rem at 85% -30%, rgba(20, 114, 235, 0.35), transparent 60%),
      var(--navy-900);
    border: 1px solid var(--navy-line);
    padding: 3.5rem 2rem;
    text-align: center;
    color: #eef4fd;
  }

  .cta-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--brand-light);
    margin: 0 0 0.75rem;
  }

  .cta h2 {
    font-size: clamp(1.5rem, 2.6vw, 1.9rem);
    margin: 0 0 0.75rem;
    color: #ffffff;
  }

  .cta p {
    color: rgba(222, 233, 248, 0.8);
    max-width: 36rem;
    margin: 0 auto 1.75rem;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-block;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(190, 211, 252, 0.35);
    color: #ffffff;
    transition: background 0.15s, border-color 0.15s;
  }

  .cta-button:hover {
    background: rgba(114, 174, 250, 0.12);
    border-color: rgba(190, 211, 252, 0.6);
    text-decoration: none;
  }

  .cta-button.primary {
    background: var(--brand);
    border-color: var(--brand);
  }

  .cta-button.primary:hover {
    background: #2c82f2;
    border-color: #2c82f2;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1020px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .trust-inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 860px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 3.5rem var(--space) 3rem;
    }

    .hero-panel {
      max-width: 30rem;
    }

    .addon-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .trust-inner {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
