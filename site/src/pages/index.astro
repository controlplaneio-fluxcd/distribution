---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroShapes from '../components/HeroShapes.astro';
import { contactUrl } from '../lib/nav';
import shotHome from '../assets/web-ui/flux-status-home-dark.png';

const trust = [
  '100% upstream compatible',
  'Maintained by Flux core maintainers',
  'SLSA Build Level 3',
  'FIPS 140-3',
];

const rows = [
  {
    eyebrow: 'security & compliance',
    title: 'Meet regulatory requirements without forking your GitOps stack',
    points: [
      {
        title: 'Zero CVEs with remediation SLAs',
        body: 'Continuous scanning and patching for controllers, base images, and Go dependencies.',
      },
      {
        title: 'FIPS 140-3 compliant builds',
        body: 'Go crypto FIPS mode with TLS and SSH restricted to approved settings.',
      },
      {
        title: 'SLSA Build Level 3 supply chain',
        body: 'Cryptographically signed images with SBOMs and VEX documents for every release.',
      },
    ],
    link: { title: 'Explore the security architecture', href: '/distribution/security/' },
    visual: 'compliance',
  },
  {
    eyebrow: 'enterprise distribution',
    title: 'Hardened Flux controllers, managed end-to-end',
    points: [
      {
        title: 'Distroless hardened images',
        body: 'No shell, no package manager, and entire classes of CVEs eliminated by design.',
      },
      {
        title: 'Extended Kubernetes compatibility',
        body: 'Tested against six minor Kubernetes releases, OpenShift, and EKS, AKS, GKE LTS versions.',
      },
      {
        title: 'Automated lifecycle with Flux Operator',
        body: 'Declarative install, upgrades, hotfixes, and CVE patches rolled out automatically.',
      },
    ],
    link: { title: 'Explore the distribution', href: '/distribution/' },
    visual: 'yaml',
  },
  {
    eyebrow: 'enterprise addons',
    title: 'Operate GitOps at scale, from dashboard to AI assistant',
    points: [
      {
        title: 'Flux Web UI',
        body: 'Real-time visibility into GitOps pipelines across all your clusters, with SSO built in.',
      },
      {
        title: 'Flux MCP Server',
        body: 'Read-only AI-assisted troubleshooting for incident response. No cluster mutations, ever.',
      },
      {
        title: 'Dex identity provider',
        body: 'OIDC single sign-on connected to your existing IdP, hardened and FIPS-compliant.',
      },
    ],
    link: { title: 'Explore the addons', href: '/addons/' },
    visual: 'addons',
  },
];

const outcomes = [
  { value: '0', label: 'Known CVEs in shipped images' },
  { value: '6', label: 'Kubernetes minor releases tested' },
  { value: 'L3', label: 'SLSA Build Level supply chain' },
  { value: '24/7', label: 'Support from Flux maintainers' },
];

const compliance = [
  { title: 'SLSA Build Level 3', body: 'Verified provenance for every artifact' },
  { title: 'FIPS 140-3', body: 'Approved cryptography end to end' },
  { title: 'Zero known CVEs', body: 'Images scanned and patched daily' },
  { title: 'Signed images + SBOMs', body: 'Cosign signatures and VEX documents' },
];
---

<BaseLayout
  title="ControlPlane Enterprise for Flux CD"
  description="ControlPlane offers a hardened, enterprise-grade distribution and support services for the CNCF-graduated Flux project."
  forcedTheme="light"
>
  <section class="hero">
    <HeroShapes />
    <div class="hero-inner">
      <a class="pill" href="/releases/release-v2.9/">
        Flux Distribution v2.9 is out
        <span class="pill-more">Release notes &rarr;</span>
      </a>
      <h1>The hardened distribution<br />of Flux&nbsp;CD</h1>
      <p class="hero-sub">Zero-CVE, FIPS-compliant GitOps for regulated environments.</p>
      <div class="hero-actions">
        <a class="hero-button" href={contactUrl} target="_blank" rel="noopener">Request a demo</a>
        <a class="hero-link" href="/distribution/overview/">Read the docs &rarr;</a>
      </div>
    </div>
  </section>

  <section class="trust" aria-label="Project pedigree">
    <div class="trust-inner">
      <p class="trust-eyebrow">Built on the CNCF-graduated Flux project</p>
      <ul>
        {trust.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <div class="rows">
    {
      rows.map(({ eyebrow, title, points, link, visual }) => (
        <section class="row">
          <div class="row-copy">
            <p class="eyebrow">{eyebrow}</p>
            <h2>{title}</h2>
            <div class="points">
              {points.map((point) => (
                <div class="point">
                  <h3>{point.title}</h3>
                  <p>{point.body}</p>
                </div>
              ))}
            </div>
            <a class="row-more" href={link.href}>
              {link.title} &rarr;
            </a>
          </div>
          <div class="row-visual">
            {visual === 'compliance' && (
              <div class="panel compliance">
                {compliance.map((row) => (
                  <div class="comp-row">
                    <svg class="check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                    <div>
                      <p class="comp-title">{row.title}</p>
                      <p class="comp-body">{row.body}</p>
                    </div>
                  </div>
                ))}
              </div>
            )}
            {visual === 'yaml' && (
              <div class="panel yaml" aria-hidden="true">
                <div class="panel-bar">
                  <span class="dot" />
                  <span class="dot" />
                  <span class="dot" />
                  <span class="panel-file">flux-instance.yaml</span>
                </div>
                <pre class="panel-code"><code><span class="yk">apiVersion</span>: fluxcd.controlplane.io/v1
<span class="yk">kind</span>: FluxInstance
<span class="yk">metadata</span>:
  <span class="yk">name</span>: flux
  <span class="yk">namespace</span>: flux-system
<span class="yk">spec</span>:
  <span class="yk">distribution</span>:
    <span class="yk">version</span>: <span class="ys">"2.x"</span>
    <span class="yk">registry</span>: ghcr.io/controlplaneio-fluxcd
    <span class="yk">variant</span>: <span class="ys">distroless-fips</span>
  <span class="yk">cluster</span>:
    <span class="yk">multitenant</span>: <span class="yb">true</span></code></pre>
                <div class="panel-status">
                  <span class="status-dot" />
                  Reconciled: enterprise distribution up to date
                </div>
              </div>
            )}
            {visual === 'addons' && (
              <div class="panel shot">
                <Image
                  src={shotHome}
                  alt="Cluster overview in the Flux Web UI with controller health, sync state and GitOps resource counters"
                  widths={[640, 1280]}
                  sizes="(min-width: 960px) 34rem, 100vw"
                />
              </div>
            )}
          </div>
        </section>
      ))
    }
  </div>

  <section class="outcomes" aria-label="Assurance in numbers">
    <div class="outcomes-inner">
      {
        outcomes.map(({ value, label }) => (
          <div class="outcome">
            <p class="outcome-value">{value}</p>
            <p class="outcome-label">{label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="cta">
    <HeroShapes />
    <div class="cta-inner">
      <h2>Run Flux in production with confidence</h2>
      <p>
        Get enterprise-hardened Flux controllers, guaranteed SLAs for CVE remediation, and direct
        access to Flux core maintainers.
      </p>
      <div class="cta-actions">
        <a class="hero-button" href={contactUrl} target="_blank" rel="noopener">Contact us</a>
        <a class="hero-link" href="/distribution/install/">Installation guide &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- Hero: navy, centered, Isovalent-scaled ---------- */
  .hero {
    position: relative;
    background:
      radial-gradient(60rem 32rem at 50% -12%, rgba(20, 114, 235, 0.35), transparent 62%),
      var(--navy-900);
    border-bottom: 1px solid var(--navy-line);
    color: #eef4fd;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    margin: 0 auto;
    padding: clamp(5rem, 10vw, 8rem) var(--space) clamp(5rem, 10vw, 7.5rem);
    text-align: center;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: #dbe7fa;
    background: rgba(14, 28, 54, 0.7);
    border: 1px solid var(--navy-line);
    border-radius: 99px;
    padding: 0.45rem 1.1rem;
    margin-bottom: 2.25rem;
  }

  .pill:hover {
    text-decoration: none;
    border-color: rgba(114, 174, 250, 0.5);
  }

  .pill-more {
    color: var(--brand-light);
    font-weight: 600;
  }

  h1 {
    font-size: var(--text-display);
    font-weight: 700;
    letter-spacing: -0.032em;
    line-height: 1.04;
    margin: 0 0 1.5rem;
    color: #ffffff;
  }

  .hero-sub {
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    color: rgba(222, 233, 248, 0.85);
    margin: 0 0 2.5rem;
  }

  .hero-actions,
  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }

  .hero-button {
    display: inline-block;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.8rem 1.9rem;
    border-radius: var(--radius-sm);
    background: var(--brand);
    border: 1px solid var(--brand);
    color: #ffffff;
    transition: background 0.15s, border-color 0.15s;
  }

  .hero-button:hover {
    background: #2c82f2;
    border-color: #2c82f2;
    text-decoration: none;
  }

  .hero-link {
    font-weight: 600;
    font-size: 1rem;
    color: #ffffff;
  }

  .hero-link:hover {
    color: var(--brand-light);
    text-decoration: none;
  }

  /* ---------- Trust bar ---------- */
  .trust {
    border-bottom: 1px solid var(--border);
    background: var(--bg-soft);
  }

  .trust-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 2rem var(--space);
    text-align: center;
  }

  .trust-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--muted);
    margin: 0 0 1rem;
  }

  .trust ul {
    list-style: none;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem 3rem;
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
  }

  .trust li {
    font-size: 1.02rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    color: var(--fg);
    opacity: 0.75;
  }

  /* ---------- Editorial rows ---------- */
  .rows {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 0 var(--space);
  }

  .row {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(2.5rem, 6vw, 5.5rem);
    align-items: center;
    padding: var(--section-pad) 0;
  }

  .row + .row {
    border-top: 1px solid var(--border);
  }

  .row:nth-child(even) .row-copy {
    order: 2;
  }

  .row:nth-child(even) .row-visual {
    order: 1;
  }

  .row h2 {
    font-size: var(--text-h2);
    line-height: 1.12;
    margin: 0 0 2rem;
  }

  .points {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    margin-bottom: 2rem;
  }

  .point h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .point p {
    font-size: 0.98rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }

  .row-more {
    font-weight: 650;
    font-size: 1rem;
  }

  /* ---------- Row visuals ---------- */
  .panel {
    border-radius: var(--radius-lg);
  }

  .panel.compliance {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    padding: 2.25rem 2rem;
    box-shadow: var(--shadow);
  }

  .comp-row {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .check {
    flex-shrink: 0;
    color: var(--ok);
    margin-top: 0.2rem;
  }

  .comp-title {
    font-weight: 700;
    font-size: 1.02rem;
    margin: 0;
  }

  .comp-body {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0.15rem 0 0;
  }

  .panel.yaml {
    background: var(--navy-950);
    border: 1px solid var(--navy-line);
    box-shadow: 0 24px 60px rgba(6, 14, 30, 0.35);
    overflow: hidden;
  }

  .panel-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--navy-line);
  }

  .dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: rgba(190, 211, 252, 0.18);
  }

  .panel-file {
    margin-left: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(190, 211, 252, 0.55);
  }

  .panel-code {
    margin: 0;
    padding: 1.1rem 1.4rem;
    border: 0;
    border-radius: 0;
    background: none;
    font-size: 0.8rem;
    line-height: 1.7;
    color: #d7e3f7;
  }

  .yk { color: var(--brand-light); }
  .ys { color: var(--brand-pale); }
  .yb { color: #34d399; }

  .panel-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.4rem;
    border-top: 1px solid var(--navy-line);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #34d399;
  }

  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #34d399;
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.7);
  }

  /* Dark Web UI screenshot framed in navy so it sits well on the light surface */
  .panel.shot {
    overflow: hidden;
    border: 1px solid var(--navy-line);
    background: var(--navy-950);
    box-shadow: 0 24px 60px rgba(6, 14, 30, 0.35);
  }

  .panel.shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ---------- Outcomes ---------- */
  .outcomes {
    border-top: 1px solid var(--border);
    background: var(--bg-soft);
  }

  .outcomes-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 4.5rem) var(--space);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .outcome-value {
    font-size: clamp(2.4rem, 4.5vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--accent);
    margin: 0;
    line-height: 1;
  }

  .outcome-label {
    font-size: 0.95rem;
    color: var(--muted);
    margin: 0.6rem 0 0;
  }

  /* ---------- CTA band ---------- */
  .cta {
    position: relative;
    background:
      radial-gradient(50rem 26rem at 50% -20%, rgba(20, 114, 235, 0.3), transparent 60%),
      var(--navy-900);
    color: #eef4fd;
    overflow: hidden;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 46rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6rem) var(--space);
    text-align: center;
  }

  .cta h2 {
    font-size: var(--text-h2);
    margin: 0 0 1rem;
    color: #ffffff;
  }

  .cta p {
    font-size: 1.05rem;
    color: rgba(222, 233, 248, 0.8);
    margin: 0 auto 2.25rem;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 960px) {
    .row {
      grid-template-columns: minmax(0, 1fr);
      gap: 2.5rem;
    }

    .row:nth-child(even) .row-copy {
      order: 1;
    }

    .row:nth-child(even) .row-visual {
      order: 2;
    }

    .row-visual {
      max-width: 32rem;
    }

    .outcomes-inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .outcomes-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .trust ul {
      gap: 0.75rem 1.75rem;
    }

    .trust li {
      font-size: 0.92rem;
    }
  }
</style>
