---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroShapes from '../components/HeroShapes.astro';
import CtaBand from '../components/CtaBand.astro';
import HybridDiagram from '../components/HybridDiagram.astro';
import { contactUrl } from '../lib/nav';
import { getReleases, type Release } from '../lib/releases';
import shotHome from '../assets/web-ui/fluxcd-web-ui-home-dark.png';
import fluxLogo from '../assets/flux-horizontal-color.svg';

/* The hero pill always announces the newest release */
const latestRelease: Release | undefined = (await getReleases())[0];

/* The alternating rows are split in two groups around the full-width
   security band; each group keeps its own copy-left/visual-right rhythm */
const rowsTop = [
  {
    eyebrow: 'assurance',
    title: 'Open source software, with someone on the hook',
    points: [
      {
        title: '24/7 incident support',
        body: 'Production outages handled around the clock by CNCF Flux maintainers and ControlPlane security engineers.',
      },
      {
        title: 'Guaranteed remediation SLAs',
        body: 'Contractual response times for CVEs and critical bugs, with fixes backported to the last three minor releases.',
      },
      {
        title: 'A direct line to the source',
        body: 'No tiered ticket queues. Escalations go to the engineers who wrote the code you run.',
      },
    ],
    link: { title: 'See the support plans', href: '/pricing/' },
    visual: 'timeline',
  },
  {
    eyebrow: 'continuous delivery',
    title: 'Deployment velocity that survives change management',
    points: [
      {
        title: 'Ship on every merge',
        body: 'Declarative delivery from Git or OCI registries to any number of clusters, with automated rollback on failure.',
      },
      {
        title: 'Automation inside approved windows',
        body: 'Time-based delivery keeps Flux within CAB-approved change windows, enforced by the platform instead of by convention.',
      },
      {
        title: 'Faster incident response',
        body: 'The Flux Web UI and MCP Server take teams from alert to root cause in minutes, with live pipeline status and AI-assisted troubleshooting.',
      },
    ],
    link: { title: 'Explore the enterprise addons', href: '/addons/' },
    visual: 'shot',
  },
];

const rowsBottom = [
  {
    eyebrow: 'hybrid & air-gapped',
    title: 'From public cloud to air-gapped, one distribution',
    points: [
      {
        title: 'Any cloud, any k8s distro',
        body: 'The same hardened Flux controllers run on EKS, AKS, GKE, OpenShift, and any CNCF-conformant Kubernetes.',
      },
      {
        title: 'Air-gapped by design',
        body: 'Mirror the entire distribution to your private registry with one command, signatures verified at the boundary.',
      },
      {
        title: 'Updates without internet access',
        body: 'Patch releases and CVE fixes flow from your own registry, on your schedule, with no outside connectivity.',
      },
    ],
    link: { title: 'Read the air-gapped guide', href: '/distribution/install/' },
    visual: 'diagram',
  },
  {
    eyebrow: 'open source sustainability',
    title: 'Your subscription keeps Flux thriving',
    points: [
      {
        title: 'Funded upstream development',
        body: 'Enterprise revenue pays the maintainers who develop, secure, and release CNCF Flux for everyone.',
      },
      {
        title: 'No lock-in by design',
        body: 'The enterprise edition is 100% compatible with the upstream APIs. Switching back to the CNCF images is a one-field change.',
      },
    ],
    link: { title: 'Read about the distribution', href: '/distribution/' },
    visual: 'banner',
  },
];

const timeline = [
  { step: 'incident', desc: 'Production reconciliation stalled, P1 raised with the support team' },
  { step: 'response', desc: 'Flux core maintainer engaged within the SLA window' },
  { step: 'remediation', desc: 'Hotfix built, signed, and rolled out by the Flux Operator' },
  { step: 'resolution', desc: 'Root cause documented, fix backported to supported releases' },
];

/* Lucide stroke icon paths (24x24) for the security band cards */
const securityIcons: Record<string, string> = {
  shield:
    '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
  lock: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  badge:
    '<path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/>',
  check:
    '<path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/>',
};

/* One entry per compliance requirement: the copy that used to be split
   between the row points and the checklist panel, merged */
const security = [
  {
    icon: 'shield',
    hue: '#067a53',
    title: 'Zero CVEs with remediation SLA',
    body: 'Continuous scanning and patching for controllers and base images.',
    status: 'patched',
  },
  {
    icon: 'lock',
    hue: '#1472eb',
    title: 'FIPS 140-3 builds',
    body: 'Go crypto FIPS mode with TLS and SSH restricted to approved settings.',
    status: 'compliant',
  },
  {
    icon: 'badge',
    hue: '#067a53',
    title: 'Signed container images',
    body: 'Authenticity and provenance verifiable with Cosign.',
    status: 'verified',
  },
  {
    icon: 'check',
    hue: '#1472eb',
    title: 'EU Cyber Resilience Act ready',
    body: 'Full SBOM traceability and compliance reporting for CRA obligations.',
    status: 'compliant',
  },
];
---

<BaseLayout
  title="ControlPlane Enterprise for Flux CD"
  description="ControlPlane offers a hardened, enterprise-grade distribution and support services for the CNCF-graduated Flux project."
  forcedTheme="light"
>
  <section class="hero">
    <HeroShapes />
    <div class="hero-inner">
      {
        latestRelease && (
          <a class="pill" href={latestRelease.href}>
            Flux {latestRelease.version} is out
            <span class="pill-more">Release notes &rarr;</span>
          </a>
        )
      }
      <h1>Run Flux in production<br />with confidence</h1>
      <p class="hero-sub">
        Ship changes to thousands of clusters with the enterprise distribution of Flux CD,
        backed by the people who build the CNCF project.
      </p>
      <div class="hero-actions">
        <a class="hero-button" href={contactUrl} target="_blank" rel="noopener">Request a demo</a>
        <a class="hero-link" href="/pricing/">See pricing &rarr;</a>
      </div>
    </div>
  </section>

  <section class="trust">
    <div class="trust-inner">
      <p class="sr-only">
        Trusted by Fortune 500 organisations and government institutions
      </p>
      <p class="trust-line" aria-hidden="true">
        <span class="trust-label">Trusted by</span>
        <span class="swap" id="trust-swap">
          <span class="swap-item is-active">Financial services</span>
          <span class="swap-item">Fortune 500 organisations</span>
          <span class="swap-item">Telecom providers</span>
          <span class="swap-item">Government institutions</span>
        </span>
      </p>
    </div>
  </section>

  <div class="rows">
    {
      rowsTop.map(({ eyebrow, title, points, link, visual }, i) => (
        <section class:list={['row', { flip: i % 2 === 1 }]}>
          <div class="row-copy">
            <p class="eyebrow">{eyebrow}</p>
            <h2>{title}</h2>
            <div class="points">
              {points.map((point) => (
                <div class="point">
                  <h3>{point.title}</h3>
                  <p>{point.body}</p>
                </div>
              ))}
            </div>
            <a class="row-more" href={link.href}>
              {link.title} &rarr;
            </a>
          </div>
          <div class="row-visual">
            {visual === 'timeline' && (
              <div class="panel timeline" aria-hidden="true">
                {timeline.map(({ step, desc }, i) => (
                  <div class="tl-row">
                    <span class="tl-step">{String(i + 1).padStart(2, '0')} {step}</span>
                    <p>{desc}</p>
                  </div>
                ))}
              </div>
            )}
            {visual === 'shot' && (
              <div class="panel shot">
                <Image
                  src={shotHome}
                  alt="Cluster overview in the Flux Web UI with controller health, sync state and GitOps resource counters"
                  widths={[640, 1280]}
                  sizes="(min-width: 960px) 34rem, 100vw"
                />
              </div>
            )}
          </div>
        </section>
      ))
    }
  </div>

  <section class="sec-band">
    <div class="sec-band-inner">
      <p class="eyebrow">security &amp; compliance</p>
      <h2>Meet regulatory requirements without forking your GitOps stack</h2>
      <div class="sec-cards">
        {
          security.map((item) => (
            <div class="sec-card" style={`--hue: ${item.hue}`}>
              <span class="sec-icon">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={securityIcons[item.icon]}
                />
              </span>
              <div class="sec-text">
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
              <span class="sec-status">{item.status}</span>
            </div>
          ))
        }
      </div>
      <a class="row-more" href="/distribution/">See how we harden Flux &rarr;</a>
    </div>
  </section>

  <div class="rows">
    {
      rowsBottom.map(({ eyebrow, title, points, link, visual }, i) => (
        <section class:list={['row', { flip: i % 2 === 0 }]}>
          <div class="row-copy">
            <p class="eyebrow">{eyebrow}</p>
            <h2>{title}</h2>
            <div class="points">
              {points.map((point) => (
                <div class="point">
                  <h3>{point.title}</h3>
                  <p>{point.body}</p>
                </div>
              ))}
            </div>
            <a class="row-more" href={link.href}>
              {link.title} &rarr;
            </a>
          </div>
          <div class="row-visual">
            {visual === 'diagram' && <HybridDiagram />}
            {visual === 'banner' && (
              <div class="panel banner">
                <img src={fluxLogo.src} alt="CNCF Flux" width="320" height="166" loading="lazy" />
                <p class="banner-caption">reconciling since 2016</p>
              </div>
            )}
          </div>
        </section>
      ))
    }
  </div>

  <CtaBand
    title="Talk to the Flux team at ControlPlane"
    body="Get a demo of the enterprise distribution and a subscription that fits your environment, from a single cluster to a whole fleet."
    primary={{ label: 'Contact us', href: contactUrl, external: true }}
    secondary={{ label: 'See the plans', href: '/pricing/' }}
  />
</BaseLayout>

<script>
  /* Rotate the trusted-by audiences in place; the container is sized to the
     widest phrase by the grid, so nothing shifts horizontally */
  const swap = document.getElementById('trust-swap');
  const items = swap ? Array.from(swap.querySelectorAll<HTMLElement>('.swap-item')) : [];
  if (swap && items.length > 1) {
    let index = 0;
    window.setInterval(() => {
      const prev = items[index];
      index = (index + 1) % items.length;
      const next = items[index];
      prev.classList.remove('is-active');
      prev.classList.add('is-leaving');
      window.setTimeout(() => prev.classList.remove('is-leaving'), 500);
      next.classList.add('is-active');
    }, 2600);
  }
</script>

<style>
  .hero {
    position: relative;
    background:
      radial-gradient(60rem 32rem at 50% -12%, rgba(20, 114, 235, 0.35), transparent 62%),
      var(--navy-900);
    border-bottom: 1px solid var(--navy-line);
    color: #eef4fd;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    margin: 0 auto;
    padding: clamp(5rem, 10vw, 8rem) var(--space) clamp(5rem, 10vw, 7.5rem);
    text-align: center;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: #dbe7fa;
    background: rgba(14, 28, 54, 0.7);
    border: 1px solid var(--navy-line);
    border-radius: 99px;
    padding: 0.45rem 1.1rem;
    margin-bottom: 2.25rem;
  }

  .pill:hover {
    text-decoration: none;
    border-color: rgba(114, 174, 250, 0.5);
  }

  .pill-more {
    color: var(--brand-light);
    font-weight: 600;
  }

  h1 {
    font-size: var(--text-display);
    font-weight: 700;
    letter-spacing: -0.032em;
    line-height: 1.04;
    margin: 0 0 1.5rem;
    color: #ffffff;
  }

  .hero-sub {
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    color: rgba(222, 233, 248, 0.85);
    margin: 0 0 2.5rem;
  }

  .trust {
    border-bottom: 1px solid var(--border);
    background: var(--bg-soft);
  }

  .trust-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 1.75rem var(--space);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .trust-line {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 1rem;
    margin: 0;
  }

  .trust-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--muted);
  }

  .swap {
    display: inline-grid;
    text-align: left;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .swap-item {
    grid-area: 1 / 1;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(0.7em);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .swap-item.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  .swap-item.is-leaving {
    opacity: 0;
    transform: translateY(-0.7em);
  }

  @media (prefers-reduced-motion: reduce) {
    .swap,
    .swap-item {
      transition: none;
    }
  }

  .row h2 {
    margin-bottom: 2rem;
  }

  .panel {
    border-radius: var(--radius-lg);
  }

  /* Security band: the one section that breaks the alternating two-column
     rhythm — a full-width tinted strip of horizontal compliance cards */
  .sec-band {
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .sec-band-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: var(--section-pad) var(--space);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .sec-band h2 {
    font-size: var(--text-h2);
    line-height: 1.12;
    text-align: center;
    max-width: 42rem;
    margin: 0 0 2.75rem;
  }

  .sec-cards {
    width: 100%;
    max-width: 52rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin-bottom: 2.5rem;
  }

  .sec-card {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.2rem 1.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow);
  }

  .sec-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--hue) 11%, var(--bg));
    color: var(--hue);
  }

  .sec-text {
    flex: 1;
    min-width: 0;
  }

  .sec-text h3 {
    font-size: 1.02rem;
    font-weight: 700;
    margin: 0;
  }

  .sec-text p {
    font-size: 0.92rem;
    color: var(--muted);
    margin: 0.2rem 0 0;
  }

  .sec-status {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    padding: 0.3rem 0.7rem;
    border-radius: 99px;
    background: color-mix(in srgb, var(--hue) 10%, var(--bg));
    color: var(--hue);
  }

  @media (max-width: 480px) {
    .sec-status {
      display: none;
    }
  }

  .panel.timeline {
    display: flex;
    flex-direction: column;
    background: var(--navy-950);
    border: 1px solid var(--navy-line);
    padding: 1.75rem 1.9rem;
    box-shadow: var(--shadow-navy);
  }

  .tl-row {
    padding: 0.9rem 0;
  }

  .tl-row + .tl-row {
    border-top: 1px solid var(--navy-line);
  }

  .tl-step {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-light);
  }

  .tl-row p {
    font-size: 0.9rem;
    color: rgba(215, 227, 247, 0.8);
    margin: 0.3rem 0 0;
  }

  .panel.banner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    min-height: 22rem;
    background:
      radial-gradient(24rem 16rem at 50% 45%, rgba(255, 255, 255, 0.9), transparent 70%),
      linear-gradient(115deg, #dcebfd 0%, #f3f8fe 42%, #ffffff 100%);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .panel.banner img {
    width: clamp(13rem, 55%, 19rem);
    height: auto;
  }

  .banner-caption {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin: 0;
  }

  /* Dark Web UI screenshot framed in navy so it sits well on the light surface */
  .panel.shot {
    overflow: hidden;
    border: 1px solid var(--navy-line);
    background: var(--navy-950);
    box-shadow: var(--shadow-navy);
  }

  .panel.shot img {
    display: block;
    width: 100%;
    height: auto;
  }

</style>
