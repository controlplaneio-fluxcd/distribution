---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroShapes from '../../components/HeroShapes.astro';
import { contactUrl } from '../../lib/nav';

const addons = [
  {
    tag: 'addon: web-ui',
    title: 'Flux Web UI',
    lead: 'A dashboard for monitoring and troubleshooting GitOps pipelines across all your Kubernetes clusters.',
    points: [
      'Real-time visibility into Flux resources, sources, and reconciliation status',
      'Multi-cluster and multi-tenant views for platform teams',
      'OIDC-based single sign-on with the Dex IdP addon',
    ],
    links: [
      { title: 'Web UI documentation', href: 'https://fluxoperator.dev/docs/web-ui/standalone-install/', external: true },
    ],
    icon: 'M3 5h18v12H3V5zm0 12l4 4h10l4-4M7 9h6m-6 4h10',
  },
  {
    tag: 'addon: mcp-server',
    title: 'Flux MCP Server',
    lead: 'A hardened, exclusively read-only MCP server that connects AI assistants to Flux-managed clusters for incident response and pipeline troubleshooting.',
    points: [
      'Read-only by design — no operation can alter cluster state, regardless of kubeconfig permissions',
      'Runs locally on dev laptops and workstations over stdio',
      'Works with Claude, Copilot, Cursor, and any MCP-compatible assistant',
    ],
    links: [
      { title: 'Local MCP Server docs', href: '/addons/mcp-stdio/' },
      { title: 'Flux Operator MCP docs', href: 'https://fluxoperator.dev/mcp-server/', external: true },
    ],
    icon: 'M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5L12 2zm7 11l.8 2.2L22 16l-2.2.8L19 19l-.8-2.2L16 16l2.2-.8L19 13zM6 15l1 2.5L9.5 18 7 19l-1 2.5L5 19l-2.5-1L5 17.5 6 15z',
  },
  {
    tag: 'addon: dex-idp',
    title: 'Dex IdP',
    lead: 'A hardened Dex distribution providing OIDC-based single sign-on for the Flux Web UI and the Flux MCP Server.',
    points: [
      'Connects to your existing identity provider — LDAP, SAML, GitHub, Google, Microsoft Entra ID, and more',
      'Hardened, FIPS-compliant container images and Helm charts',
      'Enforce identity policies across your GitOps tooling',
    ],
    links: [
      { title: 'Dex IdP docs', href: '/addons/dex/' },
    ],
    icon: 'M16 11a4 4 0 10-8 0 4 4 0 008 0zm-9 9a5 5 0 0110 0M7 11H3m18 0h-4',
  },
];
---

<BaseLayout
  title="Enterprise Addons - ControlPlane Enterprise for Flux CD"
  description="Enterprise-grade Flux addons: Web UI dashboard, AI-assisted MCP Server, and Dex single sign-on"
  forcedTheme="light"
>
  <section class="phero">
    <HeroShapes />
    <div class="phero-inner">
      <img class="glyph" src="/images/logo/enterprise-for-flux-cd-icon-white.svg" alt="" width="56" height="56" />
      <p class="phero-eyebrow">ControlPlane Enterprise</p>
      <h1>Enterprise Addons</h1>
      <p class="lead">
        Extend the Flux enterprise distribution with a web dashboard, AI-assisted troubleshooting,
        and single sign-on — hardened and covered by the same SLAs.
      </p>
      <div class="phero-actions">
        <a class="hero-button" href={contactUrl} target="_blank" rel="noopener">Request a demo</a>
        <a class="hero-link" href="/pricing/">See pricing &rarr;</a>
      </div>
    </div>
  </section>

  <div class="rows">
    {
      addons.map(({ tag, title, lead, points, links, icon }) => (
        <section class="row" aria-label={title}>
          <div class="row-copy">
            <p class="eyebrow">{tag}</p>
            <h2>{title}</h2>
            <p class="row-lead">{lead}</p>
            <ul class="points">
              {points.map((point) => (
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  {point}
                </li>
              ))}
            </ul>
            <p class="links">
              {links.map(({ title: linkTitle, href, external }) => (
                <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined}>
                  {linkTitle} &rarr;
                </a>
              ))}
            </p>
          </div>
          <div class="row-visual">
            <div class="panel">
              <div class="icon">
                <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={icon} />
                </svg>
              </div>
              <p class="panel-tag">{tag}</p>
            </div>
          </div>
        </section>
      ))
    }
  </div>

  <section class="cta">
    <HeroShapes />
    <div class="cta-inner">
      <h2>Covered by your subscription</h2>
      <p>
        All addons are included in the subscription plans and covered by ControlPlane's SLA for CVE
        remediation, with hardened images published to private registries available to customers.
      </p>
      <div class="cta-actions">
        <a class="hero-button" href="/pricing/">See the plans</a>
        <a class="hero-link" href={contactUrl} target="_blank" rel="noopener">Contact us &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .phero {
    position: relative;
    background:
      radial-gradient(56rem 30rem at 50% -12%, rgba(20, 114, 235, 0.32), transparent 62%),
      var(--navy-900);
    border-bottom: 1px solid var(--navy-line);
    color: #eef4fd;
    overflow: hidden;
  }

  .phero-inner {
    position: relative;
    z-index: 1;
    max-width: 52rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6.5rem) var(--space);
    text-align: center;
  }

  .glyph {
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: 1.25rem;
    filter: drop-shadow(0 0 18px rgba(114, 174, 250, 0.45));
  }

  .phero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--brand-light);
    margin: 0 0 1rem;
  }

  h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.06;
    margin: 0 0 1.25rem;
    color: #ffffff;
  }

  .lead {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.65;
    color: rgba(222, 233, 248, 0.85);
    margin: 0 auto 2.25rem;
    max-width: 38rem;
  }

  .phero-actions,
  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }

  .hero-button {
    display: inline-block;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.75rem 1.8rem;
    border-radius: var(--radius-sm);
    background: var(--brand);
    border: 1px solid var(--brand);
    color: #ffffff;
    transition: background 0.15s, border-color 0.15s;
  }

  .hero-button:hover {
    background: #2c82f2;
    border-color: #2c82f2;
    text-decoration: none;
  }

  .hero-link {
    font-weight: 600;
    font-size: 1rem;
    color: #ffffff;
  }

  .hero-link:hover {
    color: var(--brand-light);
    text-decoration: none;
  }

  .rows {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 0 var(--space);
  }

  .row {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
    padding: var(--section-pad) 0;
  }

  .row + .row {
    border-top: 1px solid var(--border);
  }

  .row:nth-of-type(even) .row-copy {
    order: 2;
  }

  .row:nth-of-type(even) .row-visual {
    order: 1;
  }

  h2 {
    font-size: var(--text-h2);
    line-height: 1.12;
    margin: 0 0 1rem;
  }

  .row-lead {
    font-size: 1.02rem;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 1.5rem;
  }

  .points {
    list-style: none;
    margin: 0 0 1.75rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .points li {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    font-size: 0.98rem;
  }

  .check {
    flex-shrink: 0;
    color: var(--ok);
    transform: translateY(2px);
  }

  .links {
    display: flex;
    gap: 1.75rem;
    flex-wrap: wrap;
    margin: 0;
  }

  .links a {
    font-size: 0.98rem;
    font-weight: 650;
  }

  .panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(24rem 16rem at 50% 0%, color-mix(in srgb, var(--brand) 9%, transparent), transparent 70%),
      var(--bg-soft);
    box-shadow: var(--shadow);
  }

  .icon {
    width: 5.5rem;
    height: 5.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: var(--bg);
    border: 1px solid var(--brand-light);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--brand) 8%, transparent);
    color: var(--accent);
  }

  .panel-tag {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    margin: 0;
  }

  .cta {
    position: relative;
    background:
      radial-gradient(50rem 26rem at 50% -20%, rgba(20, 114, 235, 0.3), transparent 60%),
      var(--navy-900);
    color: #eef4fd;
    overflow: hidden;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 46rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 5.5rem) var(--space);
    text-align: center;
  }

  .cta h2 {
    color: #ffffff;
    margin-bottom: 1rem;
  }

  .cta p {
    font-size: 1.02rem;
    color: rgba(222, 233, 248, 0.8);
    margin: 0 auto 2.25rem;
  }

  @media (max-width: 960px) {
    .row {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .row:nth-of-type(even) .row-copy {
      order: 1;
    }

    .row:nth-of-type(even) .row-visual {
      order: 2;
    }

    .row-visual {
      max-width: 26rem;
    }
  }
</style>
