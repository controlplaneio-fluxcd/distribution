---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroShapes from '../../components/HeroShapes.astro';
import { contactUrl } from '../../lib/nav';
import shotWorkload from '../../assets/web-ui/fluxcd-web-ui-workload-dark.png';
import shotGraph from '../../assets/web-ui/fluxcd-web-ui-graph-dark.png';
import shotLogViewer from '../../assets/web-ui/fluxcd-web-ui-log-viewer-dark.png';
import shotFavorites from '../../assets/web-ui/fluxcd-web-ui-favorites-dark.png';
import shotLogin from '../../assets/web-ui/fluxcd-web-ui-login-dark.png';
import shotSearch from '../../assets/web-ui/fluxcd-web-ui-search-dark.png';
import mcpDiagram from '../../assets/diagrams/flux-mcp-ai-assisted-gitops.png';

const webUi = {
  tag: 'addon: web-ui',
  title: 'Flux Web UI',
  lead: 'Watch your clusters converge in real time, with sources, releases, and workloads on one screen, from any device. The UI ships inside the Flux Operator, so there is nothing extra to install or operate.',
  points: [
    'Live status for everything Flux manages, from Git and OCI sources to running pods',
    'Follow a release through each stage of delivery and jump straight into events and logs',
    'Sign in with your corporate IdP over OIDC, with every action guarded by Kubernetes RBAC',
  ],
  links: [
    { title: 'Try the live demo', href: 'https://status.staging.flux-d2.com', external: true },
  ],
};

const tour = [
  {
    title: 'GitOps Graph',
    body: 'Your delivery pipeline drawn as a live graph. Follow a change from its upstream repository down to the pods it created, and watch failures light up where they start.',
    image: shotGraph,
    alt: 'GitOps dependency graph in the Flux Web UI tracing a Kustomization from its sources to workloads and resources',
  },
  {
    title: 'Log Viewer',
    body: 'A viewer that understands your logs: severity levels are picked out, stack traces grouped, and noise filtered away. It parses structured and plain-text formats from any language runtime.',
    image: shotLogViewer,
    alt: 'Pod log viewer in the Flux Web UI with severity highlighting and filters for pods, containers and log levels',
  },
  {
    title: 'Favorites',
    body: 'Build your own watchlist. Star the releases that matter, from production apps to critical infrastructure, and check their health from a single screen.',
    image: shotFavorites,
    alt: 'Favorites board in the Flux Web UI listing starred Flux resources with their readiness status',
  },
  {
    title: 'Powerful Search',
    body: 'Type a few characters and jump to any Kustomization, HelmRelease or source repository across every namespace, narrowing by kind, status or name as you go.',
    image: shotSearch,
    alt: 'Search dropdown in the Flux Web UI filtering Flux resources by kind and namespace',
  },
];

interface Addon {
  tag: string;
  title: string;
  lead: string;
  points: string[];
  links: { title: string; href: string; external?: boolean }[];
  image: ImageMetadata;
  imageAlt: string;
  lightImage?: boolean;
}

const addons: Addon[] = [
  {
    tag: 'addon: mcp-server',
    title: 'Flux MCP Server',
    lead: 'A hardened, exclusively read-only MCP server that connects AI assistants to Flux-managed clusters for incident response and pipeline troubleshooting.',
    points: [
      'Read-only by design: no operation can alter cluster state, regardless of kubeconfig permissions',
      'Runs locally on dev laptops and workstations over stdio',
      'Works with Claude, Copilot, Cursor, and any MCP-compatible assistant',
    ],
    links: [
      { title: 'Local MCP Server docs', href: '/addons/mcp-stdio/' },
    ],
    image: mcpDiagram,
    imageAlt: 'Diagram of AI-assisted GitOps where an AI assistant uses the Flux MCP Server to analyze deployments on a cluster while code changes ship through a pull request',
    lightImage: true,
  },
  {
    tag: 'addon: dex-idp',
    title: 'Dex IdP',
    lead: 'A hardened Dex distribution providing OIDC-based single sign-on for the Flux Web UI and the Flux MCP Server.',
    points: [
      'Connects to your existing identity provider: LDAP, SAML, GitHub, Google, Microsoft Entra ID, and more',
      'Hardened, FIPS-compliant container images and Helm charts',
      'Enforce identity policies across your GitOps tooling',
    ],
    links: [
      { title: 'Dex IdP docs', href: '/addons/dex/' },
    ],
    image: shotLogin,
    imageAlt: 'Flux Web UI login screen with single sign-on via OpenID Connect',
  },
];
---

<BaseLayout
  title="Enterprise Addons - ControlPlane Enterprise for Flux CD"
  description="Enterprise-grade Flux addons: Web UI dashboard, AI-assisted MCP Server, and Dex single sign-on"
  forcedTheme="light"
>
  <section class="phero">
    <HeroShapes />
    <div class="phero-inner">
      <img class="glyph" src="/images/logo/enterprise-for-flux-cd-icon-white.svg" alt="" width="56" height="56" />
      <p class="phero-eyebrow">ControlPlane Enterprise</p>
      <h1>Flux Addons</h1>
      <p class="lead">
        Extend Flux with a full-featured Web UI, AI-assisted
        troubleshooting, and single sign-on, all hardened and covered by the same SLAs.
      </p>
      <div class="phero-actions">
        <a class="hero-button" href={contactUrl} target="_blank" rel="noopener">Request a demo</a>
        <a class="hero-link" href="/pricing/">See pricing &rarr;</a>
      </div>
    </div>
  </section>

  <div class="rows">
    <section class="row" aria-label={webUi.title}>
      <div class="row-copy">
        <p class="eyebrow">{webUi.tag}</p>
        <h2>{webUi.title}</h2>
        <p class="row-lead">{webUi.lead}</p>
        <ul class="points">
          {webUi.points.map((point) => (
            <li>
              <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              {point}
            </li>
          ))}
        </ul>
        <p class="links">
          {webUi.links.map(({ title: linkTitle, href, external }) => (
            <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined}>
              {linkTitle} &rarr;
            </a>
          ))}
        </p>
      </div>
      <div class="row-visual">
        <div class="shot">
          <Image
            src={shotWorkload}
            alt="Workload view in the Flux Web UI tracing a deployment back through its Helm release to the OCI artifact it came from"
            widths={[640, 1280]}
            sizes="(min-width: 960px) 34rem, 100vw"
          />
        </div>
      </div>
    </section>
  </div>

  <section class="tour" aria-label="Flux Web UI tour">
    <div class="tour-inner">
      <p class="eyebrow">inside the flux web ui</p>
      <h2>Every stage of delivery, one dashboard</h2>
      <div class="tour-grid">
        {
          tour.map(({ title, body, image, alt }) => (
            <figure class="tour-card">
              <div class="tour-shot">
                <Image src={image} alt={alt} widths={[640, 1280]} sizes="(min-width: 960px) 36rem, 100vw" />
              </div>
              <figcaption>
                <h3>{title}</h3>
                <p>{body}</p>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <div class="rows rows-alt">
    {
      addons.map(({ tag, title, lead, points, links, image, imageAlt, lightImage }) => (
        <section class="row" aria-label={title}>
          <div class="row-copy">
            <p class="eyebrow">{tag}</p>
            <h2>{title}</h2>
            <p class="row-lead">{lead}</p>
            <ul class="points">
              {points.map((point) => (
                <li>
                  <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  {point}
                </li>
              ))}
            </ul>
            <p class="links">
              {links.map(({ title: linkTitle, href, external }) => (
                <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined}>
                  {linkTitle} &rarr;
                </a>
              ))}
            </p>
          </div>
          <div class="row-visual">
            <div class:list={['shot', { 'shot-light': lightImage }]}>
              <Image src={image} alt={imageAlt} widths={[640, 1280]} sizes="(min-width: 960px) 34rem, 100vw" />
            </div>
          </div>
        </section>
      ))
    }
  </div>

  <section class="cta">
    <HeroShapes />
    <div class="cta-inner">
      <h2>Covered by your subscription</h2>
      <p>
        All addons are included in the subscription plans and covered by ControlPlane's SLA for CVE
        remediation, with hardened images published to private registries available to customers.
      </p>
      <div class="cta-actions">
        <a class="hero-button" href="/pricing/">See the plans</a>
        <a class="hero-link" href={contactUrl} target="_blank" rel="noopener">Contact us &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .phero {
    position: relative;
    background:
      radial-gradient(56rem 30rem at 50% -12%, rgba(20, 114, 235, 0.32), transparent 62%),
      var(--navy-900);
    border-bottom: 1px solid var(--navy-line);
    color: #eef4fd;
    overflow: hidden;
  }

  .phero-inner {
    position: relative;
    z-index: 1;
    max-width: 52rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6.5rem) var(--space);
    text-align: center;
  }

  .glyph {
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: 1.25rem;
    filter: drop-shadow(0 0 18px rgba(114, 174, 250, 0.45));
  }

  .phero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--brand-light);
    margin: 0 0 1rem;
  }

  h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.06;
    margin: 0 0 1.25rem;
    color: #ffffff;
  }

  .lead {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.65;
    color: rgba(222, 233, 248, 0.85);
    margin: 0 auto 2.25rem;
    max-width: 38rem;
  }

  .phero-actions,
  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }

  .hero-button {
    display: inline-block;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.8rem 1.9rem;
    border-radius: var(--radius-sm);
    background: var(--brand);
    border: 1px solid var(--brand);
    color: #ffffff;
    transition: background 0.15s, border-color 0.15s;
  }

  .hero-button:hover {
    background: #2c82f2;
    border-color: #2c82f2;
    text-decoration: none;
  }

  .hero-link {
    font-weight: 600;
    font-size: 1rem;
    color: #ffffff;
  }

  .hero-link:hover {
    color: var(--brand-light);
    text-decoration: none;
  }

  .rows {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 0 var(--space);
  }

  .row {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
    padding: var(--section-pad) 0;
  }

  .row + .row {
    border-top: 1px solid var(--border);
  }

  .rows-alt .row:nth-of-type(odd) .row-copy {
    order: 2;
  }

  .rows-alt .row:nth-of-type(odd) .row-visual {
    order: 1;
  }

  h2 {
    font-size: var(--text-h2);
    line-height: 1.12;
    margin: 0 0 1rem;
  }

  .row-lead {
    font-size: 1.02rem;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 1.5rem;
  }

  .points {
    list-style: none;
    margin: 0 0 1.75rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .points li {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    font-size: 0.98rem;
  }

  .check {
    flex-shrink: 0;
    color: var(--ok);
    transform: translateY(2px);
  }

  .links {
    display: flex;
    gap: 1.75rem;
    flex-wrap: wrap;
    margin: 0;
  }

  .links a {
    font-size: 0.98rem;
    font-weight: 650;
  }

  /* Dark Web UI screenshots get a navy frame so they sit well on light surfaces */
  .shot {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--navy-line);
    background: var(--navy-950);
    box-shadow: var(--shadow-navy);
  }

  .shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  .shot-light {
    border-color: var(--border);
    background: #ffffff;
    box-shadow: var(--shadow);
    padding: 1rem;
  }

  .tour {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg-soft);
  }

  .tour-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: var(--section-pad) var(--space);
    text-align: center;
  }

  .tour-inner > h2 {
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }

  .tour-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(2rem, 4vw, 3rem);
    text-align: left;
  }

  .tour-card {
    margin: 0;
  }

  .tour-shot {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--navy-line);
    background: var(--navy-950);
    box-shadow: 0 18px 44px rgba(6, 14, 30, 0.28);
    aspect-ratio: 16 / 10;
  }

  .tour-shot img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .tour-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 1.4rem 0 0.4rem;
  }

  .tour-card p {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  .cta {
    position: relative;
    background:
      radial-gradient(50rem 26rem at 50% -20%, rgba(20, 114, 235, 0.3), transparent 60%),
      var(--navy-900);
    color: #eef4fd;
    overflow: hidden;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 5.5rem) var(--space);
    text-align: center;
  }

  .cta h2 {
    color: #ffffff;
    margin-bottom: 1rem;
  }

  .cta p {
    font-size: 1.02rem;
    color: rgba(222, 233, 248, 0.8);
    margin: 0 auto 2.25rem;
  }

  @media (max-width: 960px) {
    .row {
      grid-template-columns: minmax(0, 1fr);
      gap: 2.5rem;
    }

    .rows-alt .row:nth-of-type(odd) .row-copy {
      order: 1;
    }

    .rows-alt .row:nth-of-type(odd) .row-visual {
      order: 2;
    }

    .row-visual {
      max-width: 34rem;
    }

    .tour-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
