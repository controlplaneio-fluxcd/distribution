---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroShapes from '../../components/HeroShapes.astro';
import { contactUrl } from '../../lib/nav';

const whyPoints = [
  {
    title: '24/7 support from the people who build Flux',
    body: 'Production incidents, upgrade assistance, and architecture reviews handled around the clock by CNCF Flux core maintainers and ControlPlane security engineers. Nobody knows Flux better.',
  },
  {
    title: 'Guaranteed security backports',
    body: 'The enterprise distribution guarantees security updates and bug fix backports for the last three minor versions of Flux.',
  },
  {
    title: 'Hardened images',
    body: 'FIPS-compliant hardened container images for the GitOps Toolkit controllers, in-sync with the upstream CNCF Flux releases.',
  },
  {
    title: 'Extended Kubernetes compatibility',
    body: 'End-to-end tested with the latest six minor releases of Kubernetes, plus RedHat OpenShift and the LTS versions provided by AWS EKS, Azure AKS, and Google GKE.',
  },
  {
    title: 'Zero CVEs with remediation SLAs',
    body: 'Container images, OS packages, and Go dependencies are scanned and patched on a daily basis.',
  },
];

const compliance = [
  { title: '24/7 incident support', body: 'On-call access to Flux core maintainers' },
  { title: 'Zero known CVEs', body: 'Images scanned and patched daily' },
  { title: 'FIPS 140-3', body: 'Approved cryptography end to end' },
  { title: 'Signed images', body: 'Authenticity verified with Cosign' },
  { title: 'SBOMs and VEX documents', body: 'Dependency transparency and exploitability status' },
];

const pipeline = [
  { step: 'build', desc: 'FIPS-compliant binaries and multi-arch container images' },
  { step: 'patch', desc: 'CVE patches and hotfixes applied to the Open Source components' },
  { step: 'test', desc: 'Conformance tests across Kubernetes and OpenShift versions' },
  { step: 'sign', desc: 'Cosign signatures, SBOMs, and VEX documents generated' },
  { step: 'publish', desc: 'Private registries available to subscribed customers' },
];

const nextSteps = [
  { title: 'Overview', body: 'Learn what ships in the enterprise distribution and how the pieces fit together.', href: '/distribution/overview/' },
  { title: 'Installation', body: 'Deploy the enterprise distribution with the Flux Operator or bootstrap with the Flux CLI.', href: '/distribution/install/' },
  { title: 'Upgrade', body: 'Keep the Flux controllers up to date with automated upgrade workflows.', href: '/distribution/upgrade/' },
  { title: 'Security', body: 'Learn about the SLSA Build Level 3 supply chain and signed artifacts.', href: '/distribution/security/' },
];
---

<BaseLayout
  title="Flux Distribution - ControlPlane Enterprise for Flux CD"
  description="Enterprise-ready Flux CD distribution with zero CVEs, FIPS compliance, guaranteed security backports, and extended Kubernetes compatibility"
  forcedTheme="light"
>
  <section class="phero">
    <HeroShapes />
    <div class="phero-inner">
      <img class="glyph" src="/images/logo/enterprise-for-flux-cd-icon-white.svg" alt="" width="56" height="56" />
      <p class="phero-eyebrow">ControlPlane Enterprise</p>
      <h1>Flux Distribution</h1>
      <p class="lead">
        An enterprise-ready distribution of Flux CD and ecosystem tools. Fully hardened by
        ControlPlane's security team, end-to-end tested for production use.
      </p>
      <div class="phero-actions">
        <a class="hero-button" href={contactUrl} target="_blank" rel="noopener">Request a demo</a>
        <a class="hero-link" href="/distribution/overview/">Read the docs &rarr;</a>
      </div>
    </div>
  </section>

  <div class="rows">
    <section class="row">
      <div class="row-copy">
        <p class="eyebrow">why enterprise</p>
        <h2>Everything upstream Flux has, hardened for production</h2>
        <div class="points">
          {
            whyPoints.map(({ title, body }) => (
              <div class="point">
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            ))
          }
        </div>
        <a class="row-more" href="/distribution/overview/">Read the overview &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel compliance">
          {
            compliance.map((row) => (
              <div class="comp-row">
                <svg class="check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <div>
                  <p class="comp-title">{row.title}</p>
                  <p class="comp-body">{row.body}</p>
                </div>
              </div>
            ))
          }
        </div>
        <aside class="operator-note">
          <p>
            Deployment and upgrades are automated by the <a href="https://fluxoperator.dev/" target="_blank" rel="noopener">Flux Operator</a>,
            including the patching of hotfixes and CVEs affecting Flux functionality.
          </p>
        </aside>
      </div>
    </section>

    <section class="row channels-row" aria-labelledby="distribution-channels">
      <div class="channels-head">
        <p class="eyebrow">distribution channels</p>
        <h2 id="distribution-channels">Pick the variant that fits your compliance posture</h2>
      </div>
      <div class="channels">
        <div class="channel" id="distroless">
          <p class="channel-tag">variant: Debian</p>
          <h3>Distroless</h3>
          <p>
            Hardened Google Distroless-based Flux images with no shell or package managers,
            reducing the attack surface and eliminating entire classes of CVEs.
          </p>
          <p>
            Available as <code>distroless</code> and <code>distroless-fips</code>. The FIPS variant is built
            with the Go FIPS 140-3 mode, restricting TLS and SSH to FIPS-approved settings.
          </p>
        </div>
        <div class="channel" id="mainline">
          <p class="channel-tag">variant: Alpine</p>
          <h3>Mainline</h3>
          <p>Alpine Linux-based images fully compatible with the upstream Flux feature set.</p>
          <p>
            The major difference between the Flux upstream images and the ControlPlane mainline images
            is the continuous scanning and CVE patching for the container base images, OS packages,
            and Go dependencies.
          </p>
        </div>
      </div>
      <a class="row-more channels-more" href="/distribution/overview/#distribution-channels">
        Compare the distribution channels in the docs &rarr;
      </a>
    </section>

    <section class="row flip">
      <div class="row-copy">
        <p class="eyebrow">delivery pipeline</p>
        <h2>A SLSA-compliant path from source to production</h2>
        <p class="row-lead">
          The build, test and release pipeline developed by ControlPlane is compliant with the
          SLSA security framework. The distribution comprises Open Source components: the CNCF
          Flux controllers (Apache 2.0) and the Flux Operator (AGPL-3.0).
        </p>
        <a class="row-more" href="/distribution/security/">Explore the security architecture &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel pipeline">
          {
            pipeline.map(({ step, desc }, i) => (
              <div class="pipe-row">
                <span class="pipe-step">{String(i + 1).padStart(2, '0')} {step}</span>
                <p>{desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="row">
      <div class="row-copy">
        <p class="eyebrow">seamless migration</p>
        <h2>Adopt in minutes, leave whenever you want</h2>
        <div class="points">
          <div class="point">
            <h3>Zero-downtime migration</h3>
            <p>
              Moving from upstream Flux to the enterprise distribution is a one-field change:
              point the FluxInstance at the ControlPlane registry and the operator rolls out
              the hardened controllers in place, without interrupting reconciliation.
            </p>
          </div>
          <div class="point">
            <h3>No vendor lock-in</h3>
            <p>
              The distribution is 100% compatible with the upstream APIs and manifests.
              Switching back to the CNCF images is the same one-field change in reverse.
            </p>
          </div>
        </div>
        <a class="row-more" href="/distribution/install/">Read the installation guide &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel yaml" aria-hidden="true">
          <div class="panel-bar">
            <span class="dot" />
            <span class="dot" />
            <span class="dot" />
            <span class="panel-file">flux-instance.yaml</span>
          </div>
          <pre class="panel-code"><code><span class="yk">apiVersion</span>: fluxcd.controlplane.io/v1
<span class="yk">kind</span>: FluxInstance
<span class="yk">spec</span>:
  <span class="yk">distribution</span>:
    <span class="yk">version</span>: <span class="ys">"2.x"</span><span class="diff-del">-   registry: ghcr.io/fluxcd</span><span class="diff-add">+   registry: ghcr.io/controlplaneio-fluxcd/distroless</span></code></pre>
          <div class="panel-status">
            <span class="status-dot" />
            Rolling update applied, no downtime
          </div>
        </div>
      </div>
    </section>

    <section class="row channels-row" aria-labelledby="advanced-delivery">
      <div class="channels-head">
        <p class="eyebrow">advanced delivery</p>
        <h2 id="advanced-delivery">Built for the way regulated teams ship</h2>
      </div>
      <div class="channels">
        <div class="channel">
          <p class="channel-tag">delivery: time-based</p>
          <h3>Time-Based Delivery</h3>
          <p>
            Keep GitOps automation inside your change-management process. With reconciliation
            schedules, Flux applies changes only during approved windows, so CAB slots and
            peak business hours are enforced by the platform instead of by convention.
          </p>
          <a href="https://fluxoperator.dev/docs/resourcesets/time-based-delivery/" target="_blank" rel="noopener">
            Read the time-based delivery guide &rarr;
          </a>
        </div>
        <div class="channel">
          <p class="channel-tag">gitops: gitless</p>
          <h3>Gitless GitOps</h3>
          <p>
            Take the Git server out of the critical path. Production clusters pull versioned,
            signed OCI artifacts from container registries, which suits air-gapped environments
            and removes the need for Git credentials inside the cluster.
          </p>
          <a href="https://fluxoperator.dev/gitless-gitops/" target="_blank" rel="noopener">
            Learn about Gitless GitOps &rarr;
          </a>
        </div>
      </div>
    </section>

    <section class="row flip">
      <div class="row-copy">
        <p class="eyebrow">enterprise addons</p>
        <h2>Extend the distribution across your platform</h2>
        <p class="row-lead">
          Enforce identity policies, streamline incident response, and operate GitOps at scale with
          the Flux Web UI, the Flux MCP Server, and the Dex identity provider, all covered by
          ControlPlane's SLA for CVE remediation and FIPS compliance.
        </p>
        <a class="row-more" href="/addons/">Explore the enterprise addons &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel diagram" aria-hidden="true">
          <div class="dnode hub">
            <span class="dnode-kind">distribution</span>
            <span class="dnode-name">Flux Enterprise</span>
          </div>
          <div class="dstem"></div>
          <div class="drail"></div>
          <div class="dbranches">
            <div class="dbranch">
              <div class="dnode">
                <span class="dnode-kind">addon</span>
                <span class="dnode-name">Web UI</span>
              </div>
            </div>
            <div class="dbranch">
              <div class="dnode">
                <span class="dnode-kind">addon</span>
                <span class="dnode-name">MCP Server</span>
              </div>
            </div>
            <div class="dbranch">
              <div class="dnode">
                <span class="dnode-kind">addon</span>
                <span class="dnode-name">Dex IdP</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="steps-section" aria-label="Next steps">
      <p class="eyebrow">next steps</p>
      <div class="steps">
        {
          nextSteps.map(({ title, body, href }) => (
            <a class="step" href={href}>
              <h3>{title}</h3>
              <p>{body}</p>
              <span class="more">Read more &rarr;</span>
            </a>
          ))
        }
      </div>
    </section>
  </div>

  <section class="cta">
    <HeroShapes />
    <div class="cta-inner">
      <h2>Talk to the team that maintains Flux</h2>
      <p>Get a demo of the enterprise distribution and a subscription tailored to your environment.</p>
      <div class="cta-actions">
        <a class="hero-button" href={contactUrl} target="_blank" rel="noopener">Contact us</a>
        <a class="hero-link" href="/pricing/">See pricing &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- Product hero: navy, centered ---------- */
  .phero {
    position: relative;
    background:
      radial-gradient(56rem 30rem at 50% -12%, rgba(20, 114, 235, 0.32), transparent 62%),
      var(--navy-900);
    border-bottom: 1px solid var(--navy-line);
    color: #eef4fd;
    overflow: hidden;
  }

  .phero-inner {
    position: relative;
    z-index: 1;
    max-width: 52rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6.5rem) var(--space);
    text-align: center;
  }

  .glyph {
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: 1.25rem;
    filter: drop-shadow(0 0 18px rgba(114, 174, 250, 0.45));
  }

  .phero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--brand-light);
    margin: 0 0 1rem;
  }

  h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.06;
    margin: 0 0 1.25rem;
    color: #ffffff;
  }

  .lead {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.65;
    color: rgba(222, 233, 248, 0.85);
    margin: 0 auto 2.25rem;
    max-width: 38rem;
  }

  .phero-actions,
  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }

  .hero-button {
    display: inline-block;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.75rem 1.8rem;
    border-radius: var(--radius-sm);
    background: var(--brand);
    border: 1px solid var(--brand);
    color: #ffffff;
    transition: background 0.15s, border-color 0.15s;
  }

  .hero-button:hover {
    background: #2c82f2;
    border-color: #2c82f2;
    text-decoration: none;
  }

  .hero-link {
    font-weight: 600;
    font-size: 1rem;
    color: #ffffff;
  }

  .hero-link:hover {
    color: var(--brand-light);
    text-decoration: none;
  }

  /* ---------- Editorial rows ---------- */
  .rows {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 0 var(--space);
  }

  .row {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
    padding: var(--section-pad) 0;
  }

  .row + .row,
  .row + .steps-section,
  .steps-section {
    border-top: 1px solid var(--border);
  }

  .row.flip .row-copy {
    order: 2;
  }

  .row.flip .row-visual {
    order: 1;
  }

  h2 {
    font-size: var(--text-h2);
    line-height: 1.12;
    margin: 0 0 1.5rem;
  }

  .points {
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
    margin: 0.5rem 0 2rem;
  }

  .point h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .point p {
    font-size: 0.95rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }

  .row-lead {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .row-more {
    font-weight: 650;
    font-size: 1rem;
  }

  /* ---------- Visuals ---------- */
  .panel {
    border-radius: var(--radius-lg);
  }

  .panel.compliance {
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    padding: 2rem;
    box-shadow: var(--shadow);
  }

  .comp-row {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .check {
    flex-shrink: 0;
    color: var(--ok);
    margin-top: 0.2rem;
  }

  .comp-title {
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
  }

  .comp-body {
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0.15rem 0 0;
  }

  .operator-note {
    margin-top: 1rem;
    padding: 1rem 1.4rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-md);
    background: var(--bg-soft);
  }

  .operator-note p {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0;
  }

  .panel.pipeline {
    display: flex;
    flex-direction: column;
    background: var(--navy-950);
    border: 1px solid var(--navy-line);
    padding: 1.75rem 1.9rem;
    box-shadow: 0 24px 60px rgba(6, 14, 30, 0.35);
  }

  .pipe-row {
    padding: 0.9rem 0;
  }

  .pipe-row + .pipe-row {
    border-top: 1px solid var(--navy-line);
  }

  .pipe-step {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-light);
  }

  .pipe-row p {
    font-size: 0.9rem;
    color: rgba(215, 227, 247, 0.8);
    margin: 0.3rem 0 0;
  }

  /* YAML migration panel, diff-style */
  .panel.yaml {
    background: var(--navy-950);
    border: 1px solid var(--navy-line);
    box-shadow: 0 24px 60px rgba(6, 14, 30, 0.35);
    overflow: hidden;
  }

  .panel-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--navy-line);
  }

  .dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: rgba(190, 211, 252, 0.18);
  }

  .panel-file {
    margin-left: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(190, 211, 252, 0.55);
  }

  .panel-code {
    margin: 0;
    padding: 1.1rem 1.4rem;
    border: 0;
    border-radius: 0;
    background: none;
    font-size: 0.8rem;
    line-height: 1.7;
    color: #d7e3f7;
  }

  .yk { color: var(--brand-light); }
  .ys { color: var(--brand-pale); }

  .diff-del {
    display: block;
    color: #f2937f;
    background: rgba(220, 76, 44, 0.16);
    margin: 0 -1.4rem;
    padding: 0 1.4rem;
  }

  .diff-add {
    display: block;
    color: #4ade80;
    background: rgba(34, 197, 94, 0.14);
    margin: 0 -1.4rem;
    padding: 0 1.4rem;
  }

  .panel-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.4rem;
    border-top: 1px solid var(--navy-line);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #34d399;
  }

  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #34d399;
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.7);
  }

  /* Addons tree diagram, styled after the Flux Status graph */
  .panel.diagram {
    background:
      radial-gradient(20rem 12rem at 50% 0%, rgba(20, 114, 235, 0.18), transparent 70%),
      var(--navy-950);
    border: 1px solid var(--navy-line);
    padding: 2.75rem 1.75rem 3rem;
    box-shadow: 0 24px 60px rgba(6, 14, 30, 0.35);
  }

  .dnode {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    background: rgba(20, 32, 54, 0.85);
    border: 1px solid rgba(114, 174, 250, 0.35);
    border-radius: 8px;
    padding: 0.65rem 1rem;
  }

  .dnode.hub {
    width: fit-content;
    margin: 0 auto;
    align-items: center;
    text-align: center;
    border-color: var(--brand-light);
    box-shadow: 0 0 18px rgba(20, 114, 235, 0.35);
    padding: 0.75rem 1.6rem;
  }

  .dnode-kind {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(190, 211, 252, 0.55);
  }

  .dnode-name {
    font-weight: 650;
    font-size: 0.95rem;
    color: #ffffff;
    white-space: nowrap;
  }

  .dstem {
    width: 1px;
    height: 1.6rem;
    margin: 0 auto;
    background: rgba(114, 174, 250, 0.4);
  }

  .drail {
    height: 1px;
    margin: 0 calc(100% / 6);
    background: rgba(114, 174, 250, 0.4);
  }

  .dbranches {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .dbranch {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .dbranch::before {
    content: '';
    width: 1px;
    height: 1.6rem;
    background: rgba(114, 174, 250, 0.4);
  }

  .dbranch .dnode {
    width: 100%;
    align-items: center;
    text-align: center;
  }

  /* ---------- Channels ---------- */
  .channels-row {
    display: block;
  }

  .channels-head {
    max-width: 44rem;
    margin-bottom: 2.5rem;
  }

  .channels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .channel {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-soft);
    padding: 2rem 1.75rem;
    scroll-margin-top: calc(var(--header-height) + 1rem);
  }

  .channel-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: color-mix(in srgb, var(--brand) 10%, transparent);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
    margin: 0 0 0.85rem;
  }

  .channel h3 {
    margin: 0 0 0.75rem;
    font-size: 1.3rem;
  }

  .channel p,
  .channel li {
    font-size: 0.95rem;
  }

  .channel > a {
    display: inline-block;
    font-weight: 650;
    font-size: 0.95rem;
    margin-top: 0.25rem;
  }

  .channels-more {
    display: inline-block;
    margin-top: 2rem;
  }

  /* ---------- Next steps ---------- */
  .steps-section {
    padding: var(--section-pad) 0;
  }

  .steps-section h2 {
    margin-bottom: 2rem;
  }

  .steps {
