---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductHero from '../../components/ProductHero.astro';
import CtaBand from '../../components/CtaBand.astro';
import { contactUrl } from '../../lib/nav';
import { getReleases, type Release } from '../../lib/releases';

const latestRelease: Release | undefined = (await getReleases())[0];

/* The real air-gapped mirror workflow from docs/distribution/install.md,
   pinned to the latest release version */
const mirror = [
  { text: '$ flux-operator distro mirror \\', kind: 'cmd' },
  { text: '  registry.internal/fluxcd \\', kind: 'cmd' },
  { text: `  --version=${latestRelease ? `${latestRelease.version.slice(1)}.x` : 'latest'} \\`, kind: 'cmd' },
  { text: '  --variant=enterprise-distroless \\', kind: 'cmd' },
  { text: '  --verify', kind: 'cmd' },
  { text: '', kind: 'cmd' },
  { text: '✔ signatures verified with cosign', kind: 'ok' },
  { text: '✔ mirrored to registry.internal', kind: 'ok' },
];

const whyPoints = [
  {
    title: '24/7 support from the people who build Flux',
    body: 'Production incidents, upgrade assistance, and architecture reviews handled around the clock by CNCF Flux core maintainers and ControlPlane security engineers. Nobody knows Flux better.',
  },
  {
    title: 'Guaranteed security backports',
    body: 'The enterprise distribution guarantees security updates and bug fix backports for the last three minor versions of Flux.',
  },
  {
    title: 'Hardened images',
    body: 'Hardened container images for the GitOps Toolkit controllers, in-sync with the upstream CNCF Flux releases.',
  },
  {
    title: 'Extended Kubernetes compatibility',
    body: 'End-to-end tested with the latest six minor releases of Kubernetes, plus RedHat OpenShift and the LTS versions provided by AWS EKS, Azure AKS, and Google GKE.',
  },
  {
    title: 'Zero CVEs with remediation SLAs',
    body: 'Container images, OS packages, and Go dependencies are scanned and patched on a daily basis.',
  },
];

/* Only the proof points the copy column does not already state, so the panel
   adds detail instead of echoing the list next to it */
const compliance = [
  { title: 'FIPS 140-3', body: 'Approved cryptography end to end' },
  { title: 'Signed images', body: 'Cosign signatures backed by GitHub OIDC' },
  { title: 'SBOMs and VEX documents', body: 'SPDX inventories and OpenVEX exploitability status' },
];

const pipeline = [
  { step: 'patch', desc: 'CVE patches and hotfixes applied to the Flux components' },
  { step: 'build', desc: 'FIPS-compliant binaries and multi-arch container images' },
  { step: 'test', desc: 'Conformance tests across Kubernetes and OpenShift versions' },
  { step: 'sign', desc: 'Cosign signatures, SBOMs, and VEX documents generated' },
  { step: 'publish', desc: 'Container images available to customers' },
];

---

<BaseLayout
  title="Flux Distribution - ControlPlane Enterprise for Flux CD"
  description="Enterprise-ready Flux CD distribution with zero CVEs, FIPS compliance, guaranteed security backports, and extended Kubernetes compatibility"
  forcedTheme="light"
>
  <ProductHero
    title="Flux Distribution"
    lead="An enterprise-ready distribution of Flux CD and ecosystem tools. Fully hardened by ControlPlane's security team, end-to-end tested for production use."
    secondary={{ label: 'Read the docs', href: '/distribution/overview/' }}
  />

  <div class="rows">
    <section class="row">
      <div class="row-copy">
        <p class="eyebrow">why enterprise</p>
        <h2>Everything upstream Flux has, hardened for production</h2>
        <div class="points">
          {
            whyPoints.map(({ title, body }) => (
              <div class="point">
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            ))
          }
        </div>
        <a class="row-more" href="/distribution/overview/">Read the overview &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel compliance">
          {
            compliance.map((row) => (
              <div class="comp-row">
                <svg class="check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <div>
                  <p class="comp-title">{row.title}</p>
                  <p class="comp-body">{row.body}</p>
                </div>
              </div>
            ))
          }
        </div>
        <aside class="operator-note">
          <p>
            Deployment and upgrades are automated by the <a href="https://fluxoperator.dev/" target="_blank" rel="noopener">Flux Operator</a>,
            including the patching of hotfixes and CVEs affecting Flux functionality.
          </p>
        </aside>
      </div>
    </section>
  </div>

  <section class="band" aria-labelledby="distribution-channels">
    <div class="band-inner">
      <p class="eyebrow">distribution channels</p>
      <h2 id="distribution-channels">Pick the variant that fits your compliance posture</h2>
      <div class="channels">
        <div class="channel" id="distroless">
          <div class="channel-head">
          <span class="channel-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
            </svg>
          </span>
          <h3>Distroless</h3>
          </div>
          <div class="channel-body">
          <p>
            Hardened Google Distroless-based Flux images with no shell or package managers,
            reducing the attack surface and eliminating entire classes of CVEs.
          </p>
          <p>
            Available as <code>distroless</code> and <code>distroless-fips</code>. The FIPS variant is built
            with the Go FIPS 140-3 mode, restricting TLS and SSH to FIPS-approved settings.
          </p>
          </div>
        </div>
        <div class="channel" id="mainline">
          <div class="channel-head">
          <span class="channel-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z" />
              <path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65" />
              <path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65" />
            </svg>
          </span>
          <h3>Mainline</h3>
          </div>
          <div class="channel-body">
          <p>Alpine Linux-based images fully compatible with the upstream Flux feature set.</p>
          <p>
            The major difference between the Flux upstream images and the ControlPlane mainline images
            is the continuous scanning and CVE patching for the container base images, OS packages,
            and Go dependencies.
          </p>
          </div>
        </div>
      </div>
      <a class="row-more channels-more" href="/distribution/overview/#distribution-channels">
        Compare the distribution channels in the docs &rarr;
      </a>
    </div>
  </section>

  <div class="rows">
    <section class="row flip">
      <div class="row-copy">
        <p class="eyebrow">delivery pipeline</p>
        <h2>A SLSA-compliant path from source to production</h2>
        <p class="row-lead">
          The build, test and release pipeline developed by ControlPlane is compliant with the
          SLSA security framework (Build Level 3). The distribution comprises Open Source components: the CNCF
          Flux controllers (Apache 2.0) and the Flux Operator (AGPL 3.0).
        </p>
        <a class="row-more" href="/distribution/security/">Explore the security architecture &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel pipeline">
          {
            pipeline.map(({ step, desc }) => (
              <div class="pipe-row">
                <span class="pipe-step">{step}</span>
                <p>{desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="row">
      <div class="row-copy">
        <p class="eyebrow">migration</p>
        <h2>Adopt in minutes, leave whenever you want</h2>
        <div class="points">
          <div class="point">
            <h3>Zero-downtime migration</h3>
            <p>
              Moving from upstream Flux to the enterprise distribution is a one-field change:
              point the FluxInstance at the ControlPlane registry and the operator rolls out
              the hardened controllers in place.
            </p>
          </div>
          <div class="point">
            <h3>No vendor lock-in</h3>
            <p>
              The distribution is 100% compatible with the upstream APIs and manifests.
              Switching back to the CNCF images reverts that one line.
            </p>
          </div>
        </div>
        <a class="row-more" href="/distribution/install/">Read the installation guide &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel yaml" aria-hidden="true">
          <div class="panel-bar">
            <span class="dot" />
            <span class="dot" />
            <span class="dot" />
            <span class="panel-file">flux-instance.yaml</span>
          </div>
          <pre class="panel-code"><code><span class="yk">apiVersion</span>: fluxcd.controlplane.io/v1
<span class="yk">kind</span>: FluxInstance
<span class="yk">spec</span>:
  <span class="yk">distribution</span>:
    <span class="yk">version</span>: <span class="ys">"2.x"</span><span class="diff-del">-   registry: ghcr.io/fluxcd</span><span class="diff-add">+   registry: ghcr.io/controlplaneio-fluxcd/distroless</span></code></pre>
          <div class="panel-status">
            <span class="status-dot" />
            Rolling update applied, no downtime
          </div>
        </div>
      </div>
    </section>
  </div>

  <section class="band" aria-labelledby="advanced-delivery">
    <div class="band-inner">
      <p class="eyebrow">advanced delivery</p>
      <h2 id="advanced-delivery">Control when changes land, and where they come from</h2>
      <div class="channels">
        <div class="channel">
          <div class="channel-head">
          <span class="channel-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
          </span>
          <h3>Time-Based Delivery</h3>
          </div>
          <div class="channel-body">
          <p>
            Keep GitOps automation inside your change-management process. With reconciliation
            schedules, Flux applies changes only during approved windows, so CAB slots and
            peak business hours are enforced by the platform instead of by convention.
          </p>
          <a href="https://fluxoperator.dev/docs/resourcesets/time-based-delivery/" target="_blank" rel="noopener">
            Read the time-based delivery guide &rarr;
          </a>
          </div>
        </div>
        <div class="channel">
          <div class="channel-head">
          <span class="channel-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" />
              <path d="m3.3 7 8.7 5 8.7-5" />
              <path d="M12 22V12" />
            </svg>
          </span>
          <h3>Gitless GitOps</h3>
          </div>
          <div class="channel-body">
          <p>
            Take the Git server out of the critical path. Production clusters pull versioned,
            signed OCI artifacts from container registries, which suits air-gapped environments
            and removes the need for Git credentials inside the cluster.
          </p>
          <a href="https://fluxoperator.dev/gitless-gitops/" target="_blank" rel="noopener">
            Learn about Gitless GitOps &rarr;
          </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="rows">
    <section class="row">
      <div class="row-copy">
        <p class="eyebrow">air-gapped operations</p>
        <h2>Run disconnected without falling behind</h2>
        <div class="points">
          <div class="point">
            <h3>One-command mirroring</h3>
            <p>
              The Flux Operator CLI copies the entire distribution, controller images, operator,
              and Helm charts, to your private registry, verifying image signatures before the transfer.
            </p>
          </div>
          <div class="point">
            <h3>Automated offline updates</h3>
            <p>
              Patch releases and CVE fixes roll out from your own registry on your schedule,
              applied in-cluster by the Flux Operator without internet egress.
            </p>
          </div>
        </div>
        <a class="row-more" href="/distribution/install/">Read the air-gapped guide &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel terminal" aria-hidden="true">
          <div class="panel-bar">
            <span class="dot" />
            <span class="dot" />
            <span class="dot" />
          </div>
          <div class="term-body">
            {mirror.map(({ text, kind }) => (
              <span class:list={['term-line', { 'term-ok': kind === 'ok' }]}>{text}</span>
            ))}
          </div>
          <p class="term-caption">the full distribution, inside your perimeter</p>
        </div>
      </div>
    </section>

    <section class="row flip">
      <div class="row-copy">
        <p class="eyebrow">enterprise addons</p>
        <h2>Extend the distribution across your platform</h2>
        <p class="row-lead">
          The Flux Web UI, the Flux MCP Server, and the Dex identity provider add live delivery
          status, AI-assisted troubleshooting, and OIDC single sign-on to the distribution, under
          the same CVE remediation and FIPS commitments.
        </p>
        <a class="row-more" href="/addons/">Explore the enterprise addons &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel diagram" aria-hidden="true">
          <div class="dnode hub">
            <span class="dnode-kind">distribution</span>
            <span class="dnode-name">Flux Enterprise</span>
          </div>
          <div class="dstem"></div>
          <div class="drail"></div>
          <div class="dbranches">
            <div class="dbranch">
              <div class="dnode">
                <span class="dnode-kind">addon</span>
                <span class="dnode-name">Web UI</span>
              </div>
            </div>
            <div class="dbranch">
              <div class="dnode">
                <span class="dnode-kind">addon</span>
                <span class="dnode-name">MCP Server</span>
              </div>
            </div>
            <div class="dbranch">
              <div class="dnode">
                <span class="dnode-kind">addon</span>
                <span class="dnode-name">Dex IdP</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>

  <CtaBand
    title="Talk to the Flux team at ControlPlane"
    body="Get a demo of the enterprise distribution and a subscription tailored to your environment."
    primary={{ label: 'Contact us', href: contactUrl, external: true }}
    secondary={{ label: 'See pricing', href: '/pricing/' }}
  />
</BaseLayout>

<style>
  .panel {
    border-radius: var(--radius-lg);
  }

  .panel.compliance {
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    padding: 2rem;
    box-shadow: var(--shadow);
  }

  .comp-row {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .check {
    flex-shrink: 0;
    color: var(--ok);
    margin-top: 0.2rem;
  }

  .comp-title {
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
  }

  .comp-body {
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0.15rem 0 0;
  }

  .operator-note {
    margin-top: 1rem;
    padding: 1rem 1.4rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-md);
    background: var(--bg-soft);
  }

  .operator-note p {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0;
  }

  .panel.pipeline {
    display: flex;
    flex-direction: column;
    background: var(--navy-950);
    border: 1px solid var(--navy-line);
    padding: 1.75rem 1.9rem;
    box-shadow: var(--shadow-navy);
    counter-reset: stage;
  }

  /* Vertical timeline: a numbered ring per stage, connected by a rail that
     runs into the next ring (the ring's own background covers the overlap) */
  .pipe-row {
    position: relative;
    padding: 0 0 1.4rem 2.5rem;
    counter-increment: stage;
  }

  .pipe-row:last-child {
    padding-bottom: 0;
  }

  .pipe-row::before {
    content: counter(stage);
    position: absolute;
    left: 0;
    top: 0;
    width: 1.5rem;
    height: 1.5rem;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--brand-light);
    border: 1.5px solid var(--brand-light);
    border-radius: 50%;
    background: var(--navy-950);
  }

  .pipe-row::after {
    content: '';
    position: absolute;
    left: calc(0.75rem + 0.5px);
    top: calc(1.5rem + 6px);
    bottom: -0.15rem;
    width: 2px;
    background: rgba(114, 174, 250, 0.35);
  }

  .pipe-row:last-child::after {
    content: none;
  }

  .pipe-step {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.65rem;
    color: var(--brand-light);
  }

  .pipe-row p {
    font-size: 0.9rem;
    color: rgba(215, 227, 247, 0.8);
    margin: 0.3rem 0 0;
  }

  /* YAML migration panel, diff-style */
  .panel.yaml {
    background: var(--navy-950);
    border: 1px solid var(--navy-line);
    box-shadow: var(--shadow-navy);
    overflow: hidden;
  }

  .panel-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--navy-line);
  }

  .dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: rgba(190, 211, 252, 0.18);
  }

  .panel-file {
    margin-left: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(190, 211, 252, 0.55);
  }

  .panel-code {
    margin: 0;
    padding: 1.1rem 1.4rem;
    border: 0;
    border-radius: 0;
    background: none;
    font-size: 0.8rem;
    line-height: 1.7;
    color: #d7e3f7;
  }

  .yk { color: var(--brand-light); }
  .ys { color: var(--brand-pale); }

  .diff-del {
    display: block;
    color: #f2937f;
    background: rgba(220, 76, 44, 0.16);
    margin: 0 -1.4rem;
    padding: 0 1.4rem;
  }

  .diff-add {
    display: block;
    color: #4ade80;
    background: rgba(34, 197, 94, 0.14);
    margin: 0 -1.4rem;
    padding: 0 1.4rem;
  }

  .panel-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.4rem;
    border-top: 1px solid var(--navy-line);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #34d399;
  }

  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #34d399;
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.7);
  }

  /* Air-gapped mirror terminal; shares the window chrome with the YAML panel */
  .panel.terminal {
    background: var(--navy-950);
    border: 1px solid var(--navy-line);
    box-shadow: var(--shadow-navy);
    overflow: hidden;
  }

  .term-body {
    display: flex;
    flex-direction: column;
    padding: 1.1rem 1.4rem 0;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    line-height: 1.75;
    color: #d7e3f7;
    overflow-x: auto;
  }

  .term-line {
    white-space: pre;
    min-height: 1em;
  }

  .term-ok {
    color: #34d399;
  }

  .term-caption {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: rgba(190, 211, 252, 0.55);
    margin: 0;
    padding: 1.1rem 1.4rem 1.3rem;
  }

  .panel.diagram {
    background:
      radial-gradient(20rem 12rem at 50% 0%, rgba(20, 114, 235, 0.18), transparent 70%),
      var(--navy-950);
    border: 1px solid var(--navy-line);
    padding: 2.75rem 1.75rem 3rem;
    box-shadow: var(--shadow-navy);
  }

  .dnode {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    background: rgba(20, 32, 54, 0.85);
    border: 1px solid rgba(114, 174, 250, 0.35);
    border-radius: 8px;
    padding: 0.65rem 1rem;
  }

  .dnode.hub {
    width: fit-content;
    margin: 0 auto;
    align-items: center;
    text-align: center;
    border-color: var(--brand-light);
    box-shadow: 0 0 18px rgba(20, 114, 235, 0.35);
    padding: 0.75rem 1.6rem;
  }

  .dnode-kind {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(190, 211, 252, 0.55);
  }

  .dnode-name {
    font-weight: 650;
    font-size: 0.95rem;
    color: #ffffff;
    white-space: nowrap;
  }

  .dstem {
    width: 1px;
    height: 1.6rem;
    margin: 0 auto;
    background: rgba(114, 174, 250, 0.4);
  }

  .drail {
    height: 1px;
    margin: 0 calc(100% / 6);
    background: rgba(114, 174, 250, 0.4);
  }

  .dbranches {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .dbranch {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .dbranch::before {
    content: '';
    width: 1px;
    height: 1.6rem;
    background: rgba(114, 174, 250, 0.4);
  }

  .dbranch .dnode {
    width: 100%;
    align-items: center;
    text-align: center;
  }

  /* Full-width tinted bands that break the alternating row rhythm,
     matching the security band on the home page */
  .band {
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .band-inner {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: var(--section-pad) var(--space);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .band h2 {
    font-size: var(--text-h2);
    line-height: 1.12;
    text-align: center;
    max-width: 42rem;
    margin: 0 0 2.75rem;
  }

  .channels {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
