---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroShapes from '../../components/HeroShapes.astro';
import { contactUrl } from '../../lib/nav';

const whyPoints = [
  {
    title: 'Hardened images',
    body: 'FIPS-compliant hardened container images for the GitOps Toolkit controllers, in-sync with the upstream CNCF Flux releases.',
  },
  {
    title: 'Extended Kubernetes compatibility',
    body: 'End-to-end tested with the latest six minor releases of Kubernetes, plus RedHat OpenShift and the LTS versions provided by AWS EKS, Azure AKS, and Google GKE.',
  },
  {
    title: 'Zero CVEs with remediation SLAs',
    body: 'Container images continuously scanned and patched, plus SBOMs and VEX documents for images, dependencies, and build environments.',
  },
  {
    title: 'Maintained by experts',
    body: 'Security experts at ControlPlane together with CNCF Flux core maintainers, shipping hotfixes and CVE patches ahead of upstream releases.',
  },
];

const compliance = [
  { title: 'SLSA Build Level 3', body: 'Verified provenance for every artifact' },
  { title: 'FIPS 140-3', body: 'Approved cryptography end to end' },
  { title: 'Zero known CVEs', body: 'Patched ahead of upstream releases' },
  { title: 'Signed images + SBOMs', body: 'Cosign signatures and VEX documents' },
];

const pipeline = [
  { step: 'build', desc: 'FIPS-compliant binaries and multi-arch container images' },
  { step: 'patch', desc: 'CVE patches and hotfixes applied to the Open Source components' },
  { step: 'test', desc: 'Conformance tests across Kubernetes and OpenShift versions' },
  { step: 'sign', desc: 'Cosign signatures, SBOMs, and VEX documents generated' },
  { step: 'publish', desc: 'Private registries available to subscribed customers' },
];

const nextSteps = [
  { title: 'Overview', body: 'Learn what ships in the enterprise distribution and how the pieces fit together.', href: '/distribution/overview/' },
  { title: 'Installation', body: 'Deploy the enterprise distribution with the Flux Operator or bootstrap with the Flux CLI.', href: '/distribution/install/' },
  { title: 'Upgrade', body: 'Keep the Flux controllers up to date with automated upgrade workflows.', href: '/distribution/upgrade/' },
  { title: 'Security', body: 'Learn about the SLSA Build Level 3 supply chain and signed artifacts.', href: '/distribution/security/' },
];
---

<BaseLayout
  title="Enterprise Distribution - ControlPlane Enterprise for Flux CD"
  description="Hardened, FIPS-compliant Flux CD distribution with zero CVEs, enterprise support, and extended Kubernetes compatibility"
  forcedTheme="light"
>
  <section class="phero">
    <HeroShapes />
    <div class="phero-inner">
      <img class="glyph" src="/images/logo/enterprise-for-flux-cd-icon-white.svg" alt="" width="56" height="56" />
      <p class="phero-eyebrow">ControlPlane Enterprise</p>
      <h1>Enterprise Distribution</h1>
      <p class="lead">
        A secure, scalable, enterprise-ready distribution of the CNCF-graduated Flux project for
        multi-tenant Kubernetes clusters.
      </p>
      <div class="phero-actions">
        <a class="hero-button" href={contactUrl} target="_blank" rel="noopener">Request a demo</a>
        <a class="hero-link" href="/distribution/overview/">Read the docs &rarr;</a>
      </div>
    </div>
  </section>

  <div class="rows">
    <section class="row">
      <div class="row-copy">
        <p class="eyebrow">why enterprise</p>
        <h2>Everything upstream Flux has, hardened for production</h2>
        <div class="points">
          {
            whyPoints.map(({ title, body }) => (
              <div class="point">
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            ))
          }
        </div>
        <a class="row-more" href="/distribution/overview/">Read the overview &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel compliance">
          {
            compliance.map((row) => (
              <div class="comp-row">
                <svg class="check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <div>
                  <p class="comp-title">{row.title}</p>
                  <p class="comp-body">{row.body}</p>
                </div>
              </div>
            ))
          }
        </div>
        <aside class="operator-note">
          <p>
            Deployment and upgrades are automated by the <a href="https://fluxoperator.dev/" target="_blank" rel="noopener">Flux Operator</a>,
            including the patching of hotfixes and CVEs affecting Flux functionality.
          </p>
        </aside>
      </div>
    </section>

    <section class="row channels-row" aria-labelledby="distribution-channels">
      <div class="channels-head">
        <p class="eyebrow">distribution channels</p>
        <h2 id="distribution-channels">Pick the variant that fits your compliance posture</h2>
      </div>
      <div class="channels">
        <div class="channel" id="distroless">
          <p class="channel-tag">variant: distroless</p>
          <h3>Distroless</h3>
          <p>
            Hardened <a href="https://github.com/GoogleContainerTools/distroless" target="_blank" rel="noopener">Google Distroless</a>-based
            Flux images with no shell or package managers, reducing the attack surface and
            eliminating entire classes of CVEs.
          </p>
          <p>
            Available as <code>distroless</code> and <code>distroless-fips</code>. The FIPS variant is built
            with the <a href="https://go.dev/doc/security/fips140" target="_blank" rel="noopener">Go FIPS 140-3 mode</a>,
            restricting TLS and SSH to FIPS-approved settings.
          </p>
          <p>Without a shell environment and OS packages, two kustomize-controller features are disabled:</p>
          <ul>
            <li>
              <strong>Kustomize remote bases</strong>: requires the <code>git</code> binary;
              use <a href="https://fluxoperator.dev/docs/crd/gitrepository/" target="_blank" rel="noopener">GitRepository</a> or <a href="https://fluxoperator.dev/docs/crd/ocirepository/" target="_blank" rel="noopener">OCIRepository</a> sources instead.
            </li>
            <li>
              <strong>Secrets decryption with GnuPG</strong>: requires the <code>gpg</code> binary;
              use <a href="https://fluxcd.io/flux/guides/mozilla-sops/#encrypting-secrets-using-age" target="_blank" rel="noopener">Age encryption</a> or a cloud KMS provider instead.
            </li>
          </ul>
        </div>
        <div class="channel" id="mainline">
          <p class="channel-tag">variant: mainline</p>
          <h3>Mainline</h3>
          <p>
            <a href="https://www.alpinelinux.org/" target="_blank" rel="noopener">Alpine Linux</a>-based images
            fully compatible with the upstream Flux feature set.
          </p>
          <p>
            The major difference between the Flux upstream images and the ControlPlane mainline images
            is the continuous scanning and CVE patching for the container base images, OS packages,
            and Go dependencies.
          </p>
        </div>
      </div>
    </section>

    <section class="row">
      <div class="row-copy">
        <p class="eyebrow">delivery pipeline</p>
        <h2>A SLSA-compliant path from source to registry</h2>
        <p class="row-lead">
          The build, test and release pipeline developed by <a href="https://control-plane.io" target="_blank" rel="noopener">ControlPlane</a> is
          compliant with the <a href="/distribution/security/">SLSA</a> security framework. The distribution comprises Open Source
          components: the CNCF <a href="/guides/flux-architecture/#flux-controllers">Flux controllers</a> (Apache 2.0)
          and the <a href="https://fluxoperator.dev/" target="_blank" rel="noopener">Flux Operator</a> (AGPL-3.0).
        </p>
        <a class="row-more" href="/distribution/security/">Explore the security architecture &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel pipeline">
          {
            pipeline.map(({ step, desc }, i) => (
              <div class="pipe-row">
                <span class="pipe-step">{String(i + 1).padStart(2, '0')} {step}</span>
                <p>{desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="row">
      <div class="row-copy">
        <p class="eyebrow">enterprise addons</p>
        <h2>Extend the distribution across your platform</h2>
        <p class="row-lead">
          Enforce identity policies, streamline incident response, and operate GitOps at scale with
          the Flux Web UI, the Flux MCP Server, and the Dex identity provider — all covered by
          ControlPlane's SLA for CVE remediation and FIPS compliance.
        </p>
        <a class="row-more" href="/addons/">Explore the enterprise addons &rarr;</a>
      </div>
      <div class="row-visual">
        <div class="panel addons" aria-hidden="true">
          <div class="addon-node hub">
            <img src="/images/logo/enterprise-for-flux-cd-icon-colour.svg" alt="" width="28" height="28" />
            Flux Enterprise
          </div>
          <div class="addon-branches">
            <div class="addon-node">Flux Web UI</div>
            <div class="addon-node">MCP Server</div>
            <div class="addon-node">Dex IdP</div>
          </div>
        </div>
      </div>
    </section>

    <section class="steps-section" aria-labelledby="next-steps">
      <p class="eyebrow">next steps</p>
      <h2 id="next-steps">Get started with the documentation</h2>
      <div class="steps">
        {
          nextSteps.map(({ title, body, href }) => (
            <a class="step" href={href}>
              <h3>{title}</h3>
              <p>{body}</p>
              <span class="more">Read more &rarr;</span>
            </a>
          ))
        }
      </div>
    </section>
  </div>

  <section class="cta">
    <HeroShapes />
    <div class="cta-inner">
      <h2>Talk to the team that maintains Flux</h2>
      <p>Get a demo of the enterprise distribution and a subscription tailored to your environment.</p>
      <div class="cta-actions">
        <a class="hero-button" href={contactUrl} target="_blank" rel="noopener">Contact us</a>
        <a class="hero-link" href="/pricing/">See pricing &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- Product hero: navy, centered ---------- */
  .phero {
    position: relative;
    background:
      radial-gradient(56rem 30rem at 50% -12%, rgba(20, 114, 235, 0.32), transparent 62%),
      var(--navy-900);
    border-bottom: 1px solid var(--navy-line);
    color: #eef4fd;
    overflow: hidden;
  }

  .phero-inner {
    position: relative;
    z-index: 1;
    max-width: 52rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6.5rem) var(--space);
    text-align: center;
  }

  .glyph {
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: 1.25rem;
    filter: drop-shadow(0 0 18px rgba(114, 174, 250, 0.45));
  }

  .phero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--brand-light);
    margin: 0 0 1rem;
  }

  h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.06;
    margin: 0 0 1.25rem;
    color: #ffffff;
  }

  .lead {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.65;
    color: rgba(222, 233, 248, 0.85);
    margin: 0 auto 2.25rem;
    max-width: 38rem;
  }

  .phero-actions,
  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }

  .hero-button {
    display: inline-block;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.75rem 1.8rem;
    border-radius: var(--radius-sm);
    background: var(--brand);
    border: 1px solid var(--brand);
    color: #ffffff;
    transition: background 0.15s, border-color 0.15s;
  }

  .hero-button:hover {
    background: #2c82f2;
    border-color: #2c82f2;
    text-decoration: none;
  }

  .hero-link {
    font-weight: 600;
    font-size: 1rem;
    color: #ffffff;
  }

  .hero-link:hover {
    color: var(--brand-light);
    text-decoration: none;
  }

  /* ---------- Editorial rows ---------- */
  .rows {
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 0 var(--space);
  }

  .row {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
    padding: var(--section-pad) 0;
  }

  .row + .row,
  .row + .steps-section,
  .steps-section {
    border-top: 1px solid var(--border);
  }

  .row:nth-of-type(3) .row-copy {
    order: 2;
  }

  .row:nth-of-type(3) .row-visual {
    order: 1;
  }

  h2 {
    font-size: var(--text-h2);
    line-height: 1.12;
    margin: 0 0 1.5rem;
  }

  .points {
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
    margin: 0.5rem 0 2rem;
  }

  .point h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .point p {
    font-size: 0.95rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }

  .row-lead {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .row-more {
    font-weight: 650;
    font-size: 1rem;
  }

  /* ---------- Visuals ---------- */
  .panel {
    border-radius: var(--radius-lg);
  }

  .panel.compliance {
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    padding: 2rem;
    box-shadow: var(--shadow);
  }

  .comp-row {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .check {
    flex-shrink: 0;
    color: var(--ok);
    margin-top: 0.2rem;
  }

  .comp-title {
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
  }

  .comp-body {
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0.15rem 0 0;
  }

  .operator-note {
    margin-top: 1rem;
    padding: 1rem 1.4rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-md);
    background: var(--bg-soft);
  }

  .operator-note p {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0;
  }

  .panel.pipeline {
    display: flex;
    flex-direction: column;
    background: var(--navy-950);
    border: 1px solid var(--navy-line);
    padding: 1.75rem 1.9rem;
    box-shadow: 0 24px 60px rgba(6, 14, 30, 0.35);
  }

  .pipe-row {
    padding: 0.9rem 0;
  }

  .pipe-row + .pipe-row {
    border-top: 1px solid var(--navy-line);
  }

  .pipe-step {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-light);
  }

  .pipe-row p {
    font-size: 0.9rem;
    color: rgba(215, 227, 247, 0.8);
    margin: 0.3rem 0 0;
  }

  .panel.addons {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    padding: 2.5rem 2rem;
    box-shadow: var(--shadow);
  }

  .addon-node {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 650;
    font-size: 0.95rem;
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    padding: 0.7rem 1.2rem;
  }

  .addon-node.hub {
    font-size: 1.05rem;
    border-color: var(--brand-light);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--brand) 10%, transparent);
  }

  .addon-branches {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 2.25rem;
    position: relative;
  }

  .addon-branches::before {
    content: '';
    position: absolute;
    top: -2.25rem;
    left: 50%;
    width: 1px;
    height: 2.25rem;
    background: var(--border-strong);
  }

  /* ---------- Channels ---------- */
  .channels-row {
    display: block;
  }

  .channels-head {
    max-width: 44rem;
    margin-bottom: 2.5rem;
  }

  .channels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .channel {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-soft);
    padding: 2rem 1.75rem;
    scroll-margin-top: calc(var(--header-height) + 1rem);
  }

  .channel-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: color-mix(in srgb, var(--brand) 10%, transparent);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
    margin: 0 0 0.85rem;
  }

  .channel h3 {
    margin: 0 0 0.75rem;
    font-size: 1.3rem;
  }

  .channel p,
  .channel li {
    font-size: 0.95rem;
  }

  .channel ul {
    padding-left: 1.2rem;
  }

  /* ---------- Next steps ---------- */
  .steps-section {
    padding: var(--section-pad) 0;
  }

  .steps-section h2 {
    margin-bottom: 2rem;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: 1.1rem;
  }

  .step {
    display: block;
    padding: 1.4rem 1.3rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-soft);
    color: var(--fg);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .step:hover {
    text-decoration: none;
    border-color: var(--brand-light);
    box-shadow: var(--shadow);
  }

  .step h3 {
    margin: 0 0 0.4rem;
    font-size: 1.05rem;
  }

  .step p {
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }

  .more {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
  }

  /* ---------- CTA ---------- */
  .cta {
    position: relative;
    background:
      radial-gradient(50rem 26rem at 50% -20%, rgba(20, 114, 235, 0.3), transparent 60%),
      var(--navy-900);
    color: #eef4fd;
    overflow: hidden;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 46rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 5.5rem) var(--space);
    text-align: center;
  }

  .cta h2 {
    color: #ffffff;
    margin-bottom: 1rem;
  }

  .cta p {
    font-size: 1.05rem;
    color: rgba(222, 233, 248, 0.8);
    margin: 0 auto 2.25rem;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 960px) {
    .row {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .row:nth-of-type(3) .row-copy {
      order: 1;
    }

    .row:nth-of-type(3) .row-visual {
      order: 2;
    }

    .row-visual {
      max-width: 32rem;
    }

    .channels {
      grid-template-columns: 1fr;
    }
  }
</style>
